(** SMT constraint trees.

    Represents the constraints generated by refined typechecking.
    Smart constructors simplify trivial cases (Top ∧ C = C). *)

type t =
  | Top
  | Bot
  | And of t * t
  | Forall of Var.t * Sort.sort * t
  | Impl of CoreExpr.ce * t
  | Atom of CoreExpr.ce

val top : t
val bot : t
val conj : t -> t -> t
(** [conj c1 c2] is [c1 ∧ c2], simplified: [Top ∧ c = c]. *)

val impl : CoreExpr.ce -> t -> t
val forall_ : Var.t -> Sort.sort -> t -> t
val atom : CoreExpr.ce -> t

val print_gen : (Format.formatter -> Var.t -> unit) -> Format.formatter -> t -> unit
val print : Format.formatter -> t -> unit
val to_string : t -> string

module Test : sig
  val test : QCheck.Test.t list
end
