// Test: return pattern with auto — the existing open-ret + auto workflow.
//
// Exercises: log auto in return position

fun id_pred (x : Int) -> Pred Int [spec] = return x

rfun check_ret (x : Int, [res] r : (do v : Int = id_pred(x)))
  -> (y : Int, [log] (y == x)) [pure] =
  let log prop = unfold id_pred(x);
  let res r1 : (return x : Pred Int) @ v = r;
  let log eq = open-ret(r1);
  // eq : x = v [log].  We need a pure y with y == x.
  (x, log auto)

main : () [pure] = ()
