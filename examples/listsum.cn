sort List(a) = { Nil : () | Cons : (a * List(a)) }

fun listsum : List(Int) -> Int [impure] = {
  xs ->
  iter ((ys, acc) = ((xs, 0) : (List(Int) * Int))) {
    case ys of {
      Nil u -> Done acc : Step((List(Int) * Int), Int)
    | Cons (h, t) -> Next (t, acc + h) : Step((List(Int) * Int), Int)
    }
  }
}

main : () [impure] =
  let xs = Cons (1, Cons (2, Cons (3, Nil () : List(Int)) : List(Int)) : List(Int)) : List(Int);
  let r = listsum xs;
  ()
