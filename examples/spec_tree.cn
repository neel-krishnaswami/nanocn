sort tree(a) = { Leaf : a | Node : (tree(a) * tree(a)) }

spec size : tree(int) -> int = {
    Leaf x -> 1
  | Node (l, r) -> size l + size r
}

spec depth : tree(int) -> int = {
    Leaf x -> 0
  | Node (l, r) ->
      if depth l == depth r then 1 + depth l
      else 1 + depth r
}

main : () [impure] = ()
