type list(a) = { Nil : () | Cons : (a * ptr list(a)) }

fun head : list(int) -> int [pure] = {
    Nil u -> 0
  | Cons (x, rest) -> x
}

fun sumPair : (int * int) -> int [pure] = {
  (a, b) -> a + b
}

main : () [impure] =
  let xs = (Cons (42, New[list(int)] (Nil () : list(int) [pure])) : list(int) [impure]);
  let h = head xs;
  let s = sumPair (h, 1);
  ()
