sort option(a) = { Some : a | None : () }

type optionT(a) = { Some : a | None : () }

fun fromOpt : option(int) -> int [spec] = {
    Some x -> x
  | None () -> 0
}

fun unwrap : optionT(int) -> int [pure] = {
  o -> case o of {
    Some n -> n
  | None u -> 0
  }
}

fun makeOpt : int -> optionT(int) [pure] = {
  x -> Some x : optionT(int) [pure]
}

main : () [impure] =
  let o = makeOpt 42;
  let v = unwrap o;
  let p = New[int] v;
  let r = Get[int] p;
  let u = Del[int] p;
  ()
