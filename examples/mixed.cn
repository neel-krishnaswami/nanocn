sort option(a) = { Some : a | None : () }

type optionT(a) = { Some : a | None : () }

spec fromOpt : option(int) -> int = {
    Some x -> x
  | None () -> 0
}

fun unwrap(o : optionT(int)) -> int [pure] {
  case o of {
    Some n -> n
  | None u -> 0
  }
}

fun makeOpt(x : int) -> optionT(int) [pure] {
  Some x : optionT(int) [pure]
}

main : () [impure] =
  let o = makeOpt 42;
  let v = unwrap o;
  let p = New[int] v;
  let r = Get[int] p;
  let u = Del[int] p;
  ()
