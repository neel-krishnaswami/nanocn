type Seq(a) = {
    Nil : ()
  | Cons : (a * Seq(a))
}

data List(a) = {
    Nil : ()
  | Cons : (a * Ptr(List(a)))
}

fun length : Seq(Int)-> Int [spec] = {
    Nil() -> 0
  | Cons(x, xs) -> 1 + length(xs)
}

fun sequence (p : Ptr(List(Int))) -> Seq(Int) [spec] = {
  if (p == null) {
    return Nil()
  } else {
    take (x, q) = Own[List(Int)] p;
    take xs = sequence(q);
    return Cons(x, xs)
  }
}

