defns Jelaborate :: '' ::=

  defn CS ; G |- [ eff0 ] se ==> tau ~~> ce :: :: surf_synth :: 'SurfSyn_'
  {{ tex [[CS]] ; [[G]] \vdash_{[[eff0]]} [[se]] \Rightarrow [[tau]] \leadsto [[ce]] }} by

    x : tau [ eff' ] in G    eff' <= eff0
    ----------------------- :: var
    CS ; G |- [ eff0 ] x ==> tau ~~> x

    ----------------------- :: int
    CS ; G |- [ eff0 ] lit ==> int ~~> lit

    -------------------------- :: bool
    CS ; G |- [ eff0 ] blit ==> bool ~~> blit

    CS ; G |- [ eff0 ] se <== tau ~~> ce
    ---------------------------------- :: annot
    CS ; G |- [ eff0 ] se : tau ==> tau ~~> ce : tau

    prim : tau -> tau' [ eff' ]
    eff' <= eff0
    eff'' = purify eff0
    CS ; G |- [ eff'' ] se <== tau ~~> ce
    --------------------------------------------------- :: app
    CS ; G |- [ eff0 ] prim se ==> tau' ~~> prim ce

    f : tau -> tau' [ eff' ] in CS
    eff' <= eff0
    eff'' = purify eff0
    CS ; G |- [ eff'' ] se <== tau ~~> ce
    ---------------------------------------- :: call
    CS ; G |- [ eff0 ] f se ==> tau' ~~> f ce

    A eqtype
    eff' = purify eff0
    CS ; G |- [ eff' ] se1 ==> A ~~> ce1
    CS ; G |- [ eff' ] se2 <== A ~~> ce2
    ------------------------------------------------- :: eq
    CS ; G |- [ eff0 ] se1 == se2 ==> bool ~~> ce1 == ce2

  defn CS ; G |- [ eff0 ] se <== tau ~~> ce :: :: surf_check :: 'SurfChk_'
  {{ tex [[CS]] ; [[G]] \vdash_{[[eff0]]} [[se]] \Leftarrow [[tau]] \leadsto [[ce]] }} by

    CS ; G |- [ eff0 ] se1 ==> tau ~~> ce1
    eff_b = purify eff0
    CS ; G |- [ eff0 ] [ eff_b ] y , noscrs ; pat : tau --> [ empty ] [ hole ] se2 <== tau' ~~> ce2
    -------------------------------------------------------------------------- :: let
    CS ; G |- [ eff0 ] let pat = se1 ; se2 <== tau' ~~> let y = ce1 ; ce2

    CS ; G |- [ eff0 ] se1 <== tau1 ~~> ce1 .. CS ; G |- [ eff0 ] sen <== taun ~~> cen
    --------------------------------------------------- :: tuple
    CS ; G |- [ eff0 ] ( se1 , .. , sen ) <== ( tau1 , .. , taun ) ~~> ( ce1 , .. , cen )

    L : tau in D ( tau1 , .. , taui ) in CS
    eff' = purify eff0
    CS ; G |- [ eff' ] se <== tau ~~> ce
    ----------------------------------------------------------------- :: inject
    CS ; G |- [ eff0 ] L se <== D ( tau1 , .. , taui ) ~~> L ce

    eff_b = purify eff0
    CS ; G |- [ eff_b ] se ==> tau ~~> ce'
    mbranches = mk tau { pat1 --> se1 || .. || patn --> sen }
    CS ; G |- [ eff0 ] [ eff_b ] y , noscrs ; mbranches <== tau' ~~> ce
    ---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------- :: case
    CS ; G |- [ eff0 ] case se of { pat1 -> se1 | .. | patn -> sen } <== tau' ~~> let y = ce' ; ce

    CS ; G |- [ pure ] se1 ==> A ~~> ce1
    type D ( x , y ) = { Next : a , Done : b } in CS
    CS ; G |- [ impure ] [ pure ] z , noscrs ; pat : A , nobinds --> [ empty ] [ hole ] se2 <== D ( A , B ) ~~> ce2
    --------------------------------------------------------------------------------------------------------------------------------------- :: iter
    CS ; G |- [ impure ] iter ( pat = se1 ) { se2 } <== B ~~> iter ( z = ce1 ) { ce2 }

    eff' = purify eff0
    CS ; G |- [ eff' ] se1 <== bool ~~> ce1
    CS ; G |- [ eff0 ] se2 <== tau ~~> ce2
    CS ; G |- [ eff0 ] se3 <== tau ~~> ce3
    ------------------------------------------------------------------------------------- :: if
    CS ; G |- [ eff0 ] if se1 then se2 else se3 <== tau ~~> if ce1 then ce2 else ce3

    CS ; G |- [ spec ] se <== tau ~~> ce
    ---------------------------------- :: return
    CS ; G |- [ spec ] return se <== pred tau ~~> return ce

    ---------------------------------- :: fail
    CS ; G |- [ spec ] fail <== pred tau ~~> fail

    CS ; G |- [ spec ] se1 ==> pred tau ~~> ce1
    CS ; G |- [ spec ] [ spec ] y , noscrs ; pat : tau --> [ empty ] [ hole ] se2 <== pred tau' ~~> ce2
    ------------------------------------------------------------------------------------------------------------------- :: take
    CS ; G |- [ spec ] take pat = se1 ; se2 <== pred tau' ~~> take y = ce1 ; ce2

    CS ; G |- [ eff0 ] se ==> tau ~~> ce
    --------------------------------------- :: sub
    CS ; G |- [ eff0 ] se <== tau ~~> ce


