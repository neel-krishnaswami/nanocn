  defn SS ; CS |- prog ~~> cprog :: :: prog :: 'Prog_'
  {{ tex \begin{array}{ @{} l @{} } [[SS]] \vdash [[prog]] \\ \quad \leadsto [[CS]] \vdash [[cprog]] \end{array} }} by

    CS ; empty |- [ eff ] se <== tau ~~> ce
    ------------------------------------------------------ :: main
    SS ; CS |- main : tau [ eff ] = se ~~> main : tau [ eff ] = ce

    mbranches = mk A { pat1 --> se1 || .. || patn --> sen }
    CS ; empty |- [ pure ] [ pure ] y , noscrs ; mbranches <== B ~~> ce
    SS , fun f : A -> B [ pure ] = { pat1 --> se1 | .. | patn --> sen } ; CS , fun f ( y : A ) -> B [ pure ] = ce |- prog ~~> cprog
    --------------------------------------------------------------------------- :: purefun
    SS ; CS |- fun f : A -> B [ pure ] = { pat1 --> se1 | .. | patn --> sen } prog ~~> fun f ( y : A ) -> B [ pure ] = ce cprog

    mbranches = mk A { pat1 --> se1 || .. || patn --> sen }
    CS , f : A -> B [ impure ] ; empty |- [ impure ] [ pure ] y , noscrs ; mbranches <== B ~~> ce
    SS , f : A -> B [ impure ] ; CS , f : A -> B [ impure ] |- prog ~~> cprog
    ------------------------------------------------------------------------------------------------- :: impurefun
    SS ; CS |- fun f : A -> B [ impure ] = { pat1 --> se1 | .. | patn --> sen } prog ~~> fun f ( y : A ) -> B [ impure ] = ce cprog

    mbranches = mk tau { pat1 --> se1 || .. || patn --> sen }
    CS , f : tau -> tau' [ spec ] ; empty |- [ spec ] [ spec ] y , noscrs ; mbranches <== tau' ~~> ce
    SS , fun f : tau -> tau' [ spec ] = { pat1 --> se1 | .. | patn --> sen } ; CS , fun f ( y : tau ) -> tau' [ spec ] = ce |- prog ~~> cprog
    ----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------- :: specfun
    SS ; CS |- fun f : tau -> tau' [ spec ] = { pat1 --> se1 | .. | patn --> sen } prog ~~> fun f ( y : tau ) -> tau' [ spec ] = ce cprog

    CS |- sort D ( a1 , .. , ai ) = { L1 : tau1 | .. | Ln : taun } sort_ok
    SS , sort D ( a1 , .. , ai ) = { L1 : tau1 | .. | Ln : taun } ; CS , sort D ( a1 , .. , ai ) = { L1 : tau1 | .. | Ln : taun } |- prog ~~> cprog
    ---------------------------------------------------------------------------- :: sortdecl
    SS ; CS |- sort D ( a1 , .. , ai ) = { L1 : tau1 | .. | Ln : taun } prog ~~> sort D ( a1 , .. , ai ) = { L1 : tau1 | .. | Ln : taun } cprog

    CS |- type D ( a1 , .. , ai ) = { L1 : A1 | .. | Ln : An } type_ok
    SS , type D ( a1 , .. , ai ) = { L1 : A1 | .. | Ln : An } ; CS , type D ( a1 , .. , ai ) = { L1 : A1 | .. | Ln : An } |- prog ~~> cprog
    ---------------------------------------------------------------------------- :: typedecl
    SS ; CS |- type D ( a1 , .. , ai ) = { L1 : A1 | .. | Ln : An } prog ~~> type D ( a1 , .. , ai ) = { L1 : A1 | .. | Ln : An } cprog


% =============================================================================
% Pattern matching (unified)
% =============================================================================

defns Jmatch :: '' ::=

  defn mbranches has_con :: :: has_con :: 'HC_'
  {{ tex [[mbranches]] \;\mathsf{has\_con} }} by

    ---------------------------------------- :: here
    L pat : tau , binds --> [ G ] [ E ] se || mbranches has_con

    mbranches has_con
    ---------------------------------------- :: there
    binds --> [ G ] [ E ] se || mbranches has_con

  defn mbranches has_tup :: :: has_tup :: 'HT_'
  {{ tex [[mbranches]] \;\mathsf{has\_tup} }} by

    ---------------------------------------- :: here
    ( pat1 , .. , patn ) : tau , binds --> [ G ] [ E ] se || mbranches has_tup

    mbranches has_tup
    ---------------------------------------- :: there
    binds --> [ G ] [ E ] se || mbranches has_tup

  defn mbranches / var y [ eff ] ~~> mbranches' :: :: strip_var :: 'SV_'
  {{ tex [[mbranches]] \ottsym{/} \ottmv{var} \overset{[[y]]}{\leadsto}_{[[eff]]} [[mbranches']] }} by

    ---------------------------------------- :: empty
    nobranches / var y [ eff ] ~~> nobranches

    mbranches / var y [ eff ] ~~> mbranches'
    ------------------------------------------------------------------ :: cons
    x : tau , binds --> [ G ] [ E ] se || mbranches / var y [ eff ] ~~> binds --> [ G , x : tau [ eff ] ] [ let x = y ; E ] se || mbranches'

  defn mbranches / L : tau @ y [ eff ] ~~> mbranches' :: :: spec_con :: 'SC_'
  {{ tex [[mbranches]] \ottsym{/} [[L]] \mathord{:} [[tau]] \overset{[[y]]}{\leadsto}_{[[eff]]} [[mbranches']] }} by

    ------------------------------------------------------------------ :: empty
    nobranches / L : tau @ y [ eff ] ~~> nobranches

    mbranches / L : tau @ y [ eff ] ~~> mbranches'
    ------------------------------------------------------------------------------------------------ :: match
    L pat : tau' , binds --> [ G ] [ E ] se || mbranches / L : tau @ y [ eff ] ~~> pat : tau , binds --> [ G ] [ E ] se || mbranches'

    L != L'    mbranches / L : tau @ y [ eff ] ~~> mbranches'
    ------------------------------------------------------------------------------------------------ :: skip
    L' pat : tau' , binds --> [ G ] [ E ] se || mbranches / L : tau @ y [ eff ] ~~> mbranches'

    mbranches / L : tau @ y [ eff ] ~~> mbranches'
    ------------------------------------------------------------------------------------------------------------ :: var
    x : tau' , binds --> [ G ] [ E ] se || mbranches / L : tau @ y [ eff ] ~~> z : tau , binds --> [ G , x : tau' [ eff ] ] [ let x = y ; E ] se || mbranches'

  defn mbranches / tup @ y [ eff ] ~~> mbranches' :: :: expand_tup :: 'ET_'
  {{ tex [[mbranches]] \ottsym{/} \ottkw{tup} \overset{[[y]]}{\leadsto}_{[[eff]]} [[mbranches']] }} by

    -------------------------------------------------------- :: empty
    nobranches / tup @ y [ eff ] ~~> nobranches

    mbranches / tup @ y [ eff ] ~~> mbranches'
    ------------------------------------------------------------------------------------------------------------ :: tuple
    ( pat1 , .. , patk ) : ( tau1 , .. , tauk ) , binds --> [ G ] [ E ] se || mbranches / tup @ y [ eff ] ~~> pat1 : tau1 , .. , patk : tauk , binds --> [ G ] [ E ] se || mbranches'

    mbranches / tup @ y [ eff ] ~~> mbranches'
    ------------------------------------------------------------------------------------------------------------ :: var
    x : ( tau1 , .. , tauk ) , binds --> [ G ] [ E ] se || mbranches / tup @ y [ eff ] ~~> z1 : tau1 , .. , zk : tauk , binds --> [ G , x : ( tau1 , .. , tauk ) [ eff ] ] [ let x = y ; E ] se || mbranches'

  defn CS ; G |- [ eff0 ] [ eff_b ] scrs ; mbranches <== tau ~~> ce :: :: coverage :: 'Cov_'
  {{ tex [[CS]] ; [[G]] \vdash_{[[eff0]]} [[scrs]] ; [[mbranches]] \Leftarrow_{[[eff_b]]} [[tau]] \leadsto [[ce]] }} by

    CS ; G , G' |- [ eff0 ] se <== tau ~~> ce'    ce = fill E ce'
    ------------------------------------------------------------------ :: done
    CS ; G |- [ eff0 ] [ eff_b ] noscrs ; nobinds --> [ G' ] [ E ] se || mbranches <== tau ~~> ce

    mbranches / var y [ eff_b ] ~~> mbranches'
    CS ; G |- [ eff0 ] [ eff_b ] scrs ; mbranches' <== tau ~~> ce
    ------------------------------------------------ :: var
    CS ; G |- [ eff0 ] [ eff_b ] y , scrs ; mbranches <== tau ~~> ce

    mbranches has_con
    D ( a1 , .. , ak ) = { L1 : tau'1 | .. | Ln : tau'n } decl_in CS
    L1 : tau''1 in D ( tau1 , .. , taui ) in CS .. Ln : tau''n in D ( tau1 , .. , taui ) in CS
    mbranches / L1 : tau''1 @ y [ eff_b ] ~~> mbranches1 .. mbranches / Ln : tau''n @ y [ eff_b ] ~~> mbranchesn
    CS ; G |- [ eff0 ] [ eff_b ] x1 , scrs ; mbranches1 <== tau ~~> ce1 .. CS ; G |- [ eff0 ] [ eff_b ] xn , scrs ; mbranchesn <== tau ~~> cen
    --------------------------------------------------------------------------------------------------------- :: con
    CS ; G |- [ eff0 ] [ eff_b ] y , scrs ; mbranches <== tau ~~> case y of { L1 x1 -> ce1 | .. | Ln xn -> cen }

    mbranches has_tup
    mbranches / tup @ y [ eff_b ] ~~> mbranches'
    CS ; G |- [ eff0 ] [ eff_b ] y1 , .. , yn , scrs ; mbranches' <== tau ~~> ce
    ----------------------------------------------------------------------------------------------------------------- :: tup
    CS ; G |- [ eff0 ] [ eff_b ] y , scrs ; mbranches <== tau ~~> let ( y1 , .. , yn ) = y ; ce

  defn fill E ce ~~> ce' :: :: fill_ctx :: 'Fill_'
  {{ tex [[E]] [ [[ce]] ] \leadsto [[ce']] }} by

    ----------------------- :: hole
    fill hole ce ~~> ce

    fill E ce ~~> ce'
    ------------------------------------------------ :: let
    fill let x = ce'' ; E ce ~~> let x = ce'' ; ce'


% =============================================================================
% Refinement typing
% =============================================================================

defns Jrefine :: '' ::=

% -----------------------------------------------------------------------------
% Refined context well-formedness
% -----------------------------------------------------------------------------

  defn RS |- Delta rwf :: :: rctx_wf :: 'RWf_'
  {{ tex [[RS]] \vdash [[Delta]] \;\mathsf{wf} }} by

    ------------- :: empty
    RS |- rempty rwf

    RS |- Delta rwf    eff <= spec
    --------------------------------- :: eff
    RS |- Delta , x : tau [ eff ] rwf

    RS |- Delta rwf    G = erase Delta    CS = comp RS    CS ; G |- [ spec ] ce <== bool
    -------------------------------------------------------------------------------------- :: log
    RS |- Delta , x : ce [ log ] rwf

    RS |- Delta rwf    G = erase Delta    CS = comp RS    CS ; G |- [ spec ] ce ==> pred tau    CS ; G |- [ spec ] ce' <== tau
    ----------------------------------------------------------------------------------------------------------------------------- :: res
    RS |- Delta , x : ce @ ce' [ res ( u ) ] rwf


% -----------------------------------------------------------------------------
% Context erasure
% -----------------------------------------------------------------------------

  defn G = erase Delta :: :: ctx_erase :: 'Erase_'
  {{ tex [[G]] = |[[Delta]]| }} by

    ----------------------- :: empty
    empty = erase rempty

    G = erase Delta
    ------------------------------------------- :: eff
    G , x : tau [ eff ] = erase Delta , x : tau [ eff ]

    G = erase Delta
    ------------------------------------ :: log
    G = erase Delta , x : ce [ log ]

    G = erase Delta
    -------------------------------------------- :: res
    G = erase Delta , x : ce @ ce' [ res ( u ) ]


% -----------------------------------------------------------------------------
% Affinize
% -----------------------------------------------------------------------------

  defn Delta' = affinize Delta :: :: affinize :: 'Aff_'
  {{ tex [[Delta']] = \mathsf{affinize}([[Delta]]) }} by

    ----------------------------- :: empty
    rempty = affinize rempty

    Delta' = affinize Delta
    ------------------------------------------------------------ :: eff
    Delta' , x : tau [ eff ] = affinize Delta , x : tau [ eff ]

    Delta' = affinize Delta
    -------------------------------------------------------- :: log
    Delta' , x : ce [ log ] = affinize Delta , x : ce [ log ]

    Delta' = affinize Delta
    -------------------------------------------------------------------------- :: res_used
    Delta' , x : ce @ ce' [ res ( used ) ] = affinize Delta , x : ce @ ce' [ res ( used ) ]

    Delta' = affinize Delta
    -------------------------------------------------------------------------- :: res_avail
    Delta' , x : ce @ ce' [ res ( opt ) ] = affinize Delta , x : ce @ ce' [ res ( avail ) ]

    Delta' = affinize Delta
    -------------------------------------------------------------------------- :: res_opt
    Delta' , x : ce @ ce' [ res ( opt ) ] = affinize Delta , x : ce @ ce' [ res ( opt ) ]


% -----------------------------------------------------------------------------
% Zero check (all resources consumed or optional)
% -----------------------------------------------------------------------------

  defn zero Delta :: :: zero :: 'Zero_'
  {{ tex \mathsf{zero}([[Delta]]) }} by

    ------------- :: empty
    zero rempty

    zero Delta
    ----------------------------- :: eff
    zero Delta , x : tau [ eff ]

    zero Delta
    ----------------------------- :: log
    zero Delta , x : ce [ log ]

    zero Delta    u in_zero
    --------------------------------------- :: res
    zero Delta , x : ce @ ce' [ res ( u ) ]


% -----------------------------------------------------------------------------
% Context-to-constraint (closing)
% -----------------------------------------------------------------------------

  defn Ct = close Delta Ct' :: :: ctx_close :: 'Close_'
  {{ tex [[Ct]] = [[Delta]] \Rightarrow [[Ct']] }} by

    ----------------------- :: empty
    Ct = close rempty Ct

    Ct = close Delta forall x : tau . Ct'
    ----------------------------------------------- :: eff
    Ct = close Delta , x : tau [ eff ] Ct'

    Ct = close Delta ce cimp Ct'
    --------------------------------------- :: log
    Ct = close Delta , x : ce [ log ] Ct'

    Ct = close Delta Ct'
    ------------------------------------------------- :: res
    Ct = close Delta , x : ce @ ce' [ res ( u ) ] Ct'


% -----------------------------------------------------------------------------
% Constraint well-formedness
% -----------------------------------------------------------------------------

  defn RS ; G |- Ct cwf :: :: ct_wf :: 'CtWf_'
  {{ tex [[RS]] ; [[G]] \vdash [[Ct]] \;\mathsf{wf} }} by

    -------------------- :: top
    RS ; G |- Top cwf

    RS ; G |- Ct1 cwf    RS ; G |- Ct2 cwf
    ----------------------------------------- :: and
    RS ; G |- Ct1 cand Ct2 cwf

    RS ; G , x : tau [ spec ] |- Ct cwf
    -------------------------------------- :: forall
    RS ; G |- forall x : tau . Ct cwf

    CS = comp RS    CS ; G |- [ spec ] ce <== bool    RS ; G |- Ct cwf
    --------------------------------------------------------------------- :: impl
    RS ; G |- ce cimp Ct cwf

    CS = comp RS    CS ; G |- [ spec ] ce <== bool
    ------------------------------------------------- :: atom
    RS ; G |- Ct_ce ce cwf

    -------------------- :: bot
    RS ; G |- Bot cwf


% -----------------------------------------------------------------------------
% Proof sort well-formedness
% -----------------------------------------------------------------------------

  defn RS ; G |- [ eff ] Pf pfwf :: :: pf_wf :: 'PfWf_'
  {{ tex [[RS]] ; [[G]] \vdash_{[[eff]]} [[Pf]] \;\mathsf{wf} }} by

    ----------------------------- :: nil
    RS ; G |- [ eff ] pfnil pfwf

    eff' in_pfeff eff
    RS ; G , x : tau [ eff' ] |- [ eff ] Pf pfwf
    ------------------------------------------------ :: comp
    RS ; G |- [ eff ] x : tau [ eff' ] , Pf pfwf

    CS = comp RS    CS ; G |- [ spec ] ce <== bool    RS ; G |- [ eff ] Pf pfwf
    ------------------------------------------------------------------------------- :: log
    RS ; G |- [ eff ] ce [ log ] , Pf pfwf

    CS = comp RS    CS ; G |- [ spec ] ce' ==> tau    CS ; G |- [ spec ] ce <== pred tau    RS ; G |- [ eff ] Pf pfwf
    --------------------------------------------------------------------------------------------------------------------- :: res
    RS ; G |- [ eff ] ce @ ce' [ res ] , Pf pfwf

    CS = comp RS    CS ; G |- [ spec ] ce ==> pred tau    RS ; G , y : tau [ spec ] |- [ eff ] Pf pfwf
    -------------------------------------------------------------------------------------------------------- :: depres
    RS ; G |- [ eff ] ( y ) . ce [ res ] , Pf pfwf


% -----------------------------------------------------------------------------
% Refined function type well-formedness
% -----------------------------------------------------------------------------

  defn RS |- RF rfwf :: :: rf_wf :: 'RFWf_'
  {{ tex [[RS]] \vdash [[RF]] \;\mathsf{wf} }} by

    RS ; empty |- [ eff ] Pf1 pfwf    G = bind Pf1    RS ; G |- [ eff ] Pf2 pfwf
    -------------------------------------------------------------------------------- :: rfun
    RS |- Pf1 -o Pf2 [ eff ] rfwf


% -----------------------------------------------------------------------------
% Refined signature lookup
% -----------------------------------------------------------------------------

  defn RS |- f : RF :: :: rsig_lookup :: 'RSLk_'
  {{ tex [[RS]] \vdash [[f]] \mathord{:} [[RF]] }} by

    f : RF in RS
    -------------------- :: rfun
    RS |- f : RF

    f : tau -> tau' [ eff ] in RS
    ------------------------------------------------ :: sig
    RS |- f : x : tau [ eff ] , pfnil -o y : tau' [ eff ] , pfnil [ eff ]

    f : tau -> tau' [ eff ] = ce in RS
    ------------------------------------------------ :: def
    RS |- f : x : tau [ eff ] , pfnil -o y : tau' [ eff ] , pfnil [ eff ]


% -----------------------------------------------------------------------------
% Proof sort erasure
% -----------------------------------------------------------------------------

  defn AL = pf_types Pf :: :: pf_types :: 'PfTys_'
  {{ tex [[AL]] = \{[[Pf]]\} }} by

    ----------------------- :: nil
    alnil = pf_types pfnil

    AL = pf_types Pf
    ------------------------------------------- :: pure
    A ,, AL = pf_types x : A [ pure ] , Pf

    AL = pf_types Pf
    ------------------------------------------- :: spec
    AL = pf_types x : tau [ spec ] , Pf

    AL = pf_types Pf
    ------------------------------------------- :: log
    AL = pf_types ce [ log ] , Pf

    AL = pf_types Pf
    ------------------------------------------- :: res
    AL = pf_types ce @ ce' [ res ] , Pf

    AL = pf_types Pf
    --------------------------------------------------- :: depres
    AL = pf_types ( y ) . ce [ res ] , Pf


% -----------------------------------------------------------------------------
% Proof sort to context (REMOVED — replaced by pattern matching judgement)
% -----------------------------------------------------------------------------


% -----------------------------------------------------------------------------
% Refined signature erasure
% -----------------------------------------------------------------------------

  defn CS = comp RS :: :: rsig_erase :: 'RSErase_'
  {{ tex [[CS]] = \mathsf{Comp}([[RS]]) }} by

    ----------------------- :: empty
    noprims = comp norprims

    CS = comp RS
    ------------------------------------------- :: ext
    CS , f : F = comp RS , f : F

    CS = comp RS
    ----------------------------------------------------------------- :: fundef
    CS , fun f ( x : tau ) -> tau' [ eff ] = ce = comp RS , fun f ( x : tau ) -> tau' [ eff ] = ce

    CS = comp RS    AL1 = pf_types Pf1    A = prod AL1    AL2 = pf_types Pf2    B = prod AL2
    -------------------------------------------------------------------------------------- :: rfun
    CS , f : A -> B [ eff ] = comp RS , f : Pf1 -o Pf2 [ eff ]

    CS = comp RS
    -------------------------------------------------------------------------------------- :: sort
    CS , sort D ( a1 , .. , ai ) = { L1 : tau1 | .. | Ln : taun } = comp RS , sort D ( a1 , .. , ai ) = { L1 : tau1 | .. | Ln : taun }

    CS = comp RS
    -------------------------------------------------------------------------------------- :: type
    CS , type D ( a1 , .. , ai ) = { L1 : A1 | .. | Ln : An } = comp RS , type D ( a1 , .. , ai ) = { L1 : A1 | .. | Ln : An }


% -----------------------------------------------------------------------------
% Refined signature well-formedness
% -----------------------------------------------------------------------------

  defn |- RS rswf :: :: rsig_wf :: 'RSWf_'
  {{ tex \vdash [[RS]] \;\mathsf{wf} }} by

    ------------- :: empty
    |- norprims rswf

    |- RS rswf
    -------------------------- :: ext
    |- RS , f : F rswf

    |- RS rswf    CS = comp RS    CS ; G , x : tau [ eff ] |- [ eff ] ce <== tau'
    ------------------------------------------------------------------------------ :: fundef
    |- RS , fun f ( x : tau ) -> tau' [ eff ] = ce rswf

    |- RS rswf    CS = comp RS    RS |- RF rfwf
    ------------------------------------------------ :: rfun
    |- RS , f : RF rswf


% -----------------------------------------------------------------------------
% Logical fact synthesis
% -----------------------------------------------------------------------------

  defn RS ; Delta |- lpf l==> ce -| Delta' ~~> Ct :: :: lpf_synth :: 'LSyn_'
  {{ tex [[RS]] ; [[Delta]] \vdash [[lpf]] \Rightarrow [[ce]] \dashv [[Delta']] \leadsto [[Ct]] }} by

    x : ce [ log ] in Delta
    ---------------------------------------- :: var
    RS ; Delta |- x l==> ce -| Delta ~~> Top

    CS = comp RS    f : tau -> tau' [ eff ] = ce' in CS    eff <= spec
    G = erase Delta    CS ; G |- [ spec ] ce <== tau
    ------------------------------------------------------------------ :: unfold
    RS ; Delta |- unfold f ( ce ) l==> ( f ce ) == app_s id G , ce / x ce' -| Delta ~~> Top

    RS ; Delta |- lpf l<== ce -| Delta' ~~> Ct
    ------------------------------------------------ :: annot
    RS ; Delta |- lpf : ce l==> ce -| Delta' ~~> Ct

    RS ; Delta |- rpf r==> return ce @ ce' -| Delta' ~~> Ct
    ----------------------------------------------------------- :: openret
    RS ; Delta |- open-ret rpf l==> ce == ce' -| Delta' ~~> Ct


% -----------------------------------------------------------------------------
% Logical fact checking
% -----------------------------------------------------------------------------

  defn RS ; Delta |- lpf l<== ce -| Delta' ~~> Ct :: :: lpf_check :: 'LChk_'
  {{ tex [[RS]] ; [[Delta]] \vdash [[lpf]] \Leftarrow [[ce]] \dashv [[Delta']] \leadsto [[Ct]] }} by

    -------------------------------------------- :: auto
    RS ; Delta |- auto l<== ce -| Delta ~~> Ct_ce ce

    RS ; Delta |- lpf l==> ce -| Delta' ~~> Ct
    ---------------------------------------------------------------- :: sub
    RS ; Delta |- lpf l<== ce' -| Delta' ~~> Ct cand ( ce cimp ( Ct_ce ce' ) )


% -----------------------------------------------------------------------------
% Resource variable lookup
% -----------------------------------------------------------------------------

  defn RS ; Delta |- x r: ce @ ce' -| Delta' :: :: res_lookup :: 'RLk_'
  {{ tex [[RS]] ; [[Delta]] \vdash [[x]] : [[ce]] @ [[ce']] \dashv [[Delta']] }} by

    x != y    RS ; Delta |- x r: ce @ ce' -| Delta'
    ----------------------------------------------------------------- :: there_eff
    RS ; Delta , y : tau [ eff ] |- x r: ce @ ce' -| Delta' , y : tau [ eff ]

    x != y    RS ; Delta |- x r: ce @ ce' -| Delta'
    ----------------------------------------------------------------- :: there_log
    RS ; Delta , y : ce'' [ log ] |- x r: ce @ ce' -| Delta' , y : ce'' [ log ]

    x != y    RS ; Delta |- x r: ce @ ce' -| Delta'
    ----------------------------------------------------------------- :: there_res
    RS ; Delta , y : ce'' @ ce''' [ res ( u ) ] |- x r: ce @ ce' -| Delta' , y : ce'' @ ce''' [ res ( u ) ]

    u in_avail
    -------------------------------------------------------------------------------------- :: here
    RS ; Delta , x : ce @ ce' [ res ( u ) ] |- x r: ce @ ce' -| Delta , x : ce @ ce' [ res ( used ) ]


% -----------------------------------------------------------------------------
% Resource fact synthesis
% -----------------------------------------------------------------------------

  defn RS ; Delta |- rpf r==> ce @ ce' -| Delta' ~~> Ct :: :: rpf_synth :: 'RSyn_'
  {{ tex [[RS]] ; [[Delta]] \vdash [[rpf]] \Rightarrow [[ce]] @ [[ce']] \dashv [[Delta']] \leadsto [[Ct]] }} by

    RS ; Delta |- x r: ce @ ce' -| Delta'
    -------------------------------------------------- :: var
    RS ; Delta |- x r==> ce @ ce' -| Delta' ~~> Top

    RS ; Delta |- rpf r<== ce @ ce' -| Delta' ~~> Ct
    ------------------------------------------------------ :: annot
    RS ; Delta |- rpf : ce @ ce' r==> ce @ ce' -| Delta' ~~> Ct


% -----------------------------------------------------------------------------
% Resource fact checking
% -----------------------------------------------------------------------------

  defn RS ; Delta |- rpf r<== ce @ ce' -| Delta' ~~> Ct :: :: rpf_check :: 'RChk_'
  {{ tex [[RS]] ; [[Delta]] \vdash [[rpf]] \Leftarrow [[ce]] @ [[ce']] \dashv [[Delta']] \leadsto [[Ct]] }} by

    RS ; Delta |- lpf l<== ce1 == ce2 -| Delta' ~~> Ct
    ---------------------------------------------------------------- :: makeret
    RS ; Delta |- make-ret lpf r<== return ce1 @ ce2 -| Delta' ~~> Ct

    RS ; Delta |- [ eff ] crt r<== x : tau [ spec ] , ce1 @ x [ res ] , ce2 @ ce3 [ res ] , pfnil -| Delta' ~~> Ct
    ---------------------------------------------------------------- :: maketake
    RS ; Delta |- make-take crt r<== take x = ce1 ; ce2 @ ce3 -| Delta' ~~> Ct

    RS ; Delta |- rpf r==> ce1 @ ce1' -| Delta' ~~> Ct
    ---------------------------------------------------------------------- :: sub
    RS ; Delta |- rpf r<== ce2 @ ce2' -| Delta' ~~> ( Ct cand Ct_ce ( ce1 == ce2 ) ) cand Ct_ce ( ce1' == ce2' )


% -----------------------------------------------------------------------------
% Proof sort equality
% -----------------------------------------------------------------------------

  defn RS ; Delta |- Pf1 pfeq Pf2 ~~> Ct :: :: pf_eq :: 'PfEq_'
  {{ tex [[RS]] ; [[Delta]] \vdash [[Pf1]] = [[Pf2]] \leadsto [[Ct]] }} by

    -------------------------------------------- :: nil
    RS ; Delta |- pfnil pfeq pfnil ~~> Top

    RS ; Delta , x : tau [ eff ] |- Pf1 pfeq app_s id erase Delta , x / y Pf2 ~~> Ct
    ----------------------------------------------------------------------- :: comp
    RS ; Delta |- x : tau [ eff ] , Pf1 pfeq y : tau [ eff ] , Pf2 ~~> forall x : tau . Ct

    RS ; Delta |- Pf1 pfeq Pf2 ~~> Ct
    -------------------------------------------------------------------------- :: log
    RS ; Delta |- ce1 [ log ] , Pf1 pfeq ce2 [ log ] , Pf2 ~~> ( Ct_ce ( ce1 == ce2 ) ) cand Ct

    RS ; Delta |- Pf1 pfeq Pf2 ~~> Ct
    -------------------------------------------------------------------------------------------------- :: res
    RS ; Delta |- ce1 @ ce1' [ res ] , Pf1 pfeq ce2 @ ce2' [ res ] , Pf2 ~~> ( ( Ct_ce ( ce1 == ce2 ) ) cand Ct_ce ( ce1' == ce2' ) ) cand Ct

    G = erase Delta    CS = comp RS    CS ; G |- [ spec ] ce1 ==> pred tau    CS ; G |- [ spec ] ce2 ==> pred tau
    RS ; Delta , z : tau [ spec ] |- app_s id erase Delta , z / y Pf1 pfeq app_s id erase Delta , z / w Pf2 ~~> Ct
    -------------------------------------------------------------------------------------------------------------------------- :: depres
    RS ; Delta |- ( y ) . ce1 [ res ] , Pf1 pfeq ( w ) . ce2 [ res ] , Pf2 ~~> ( Ct_ce ( ce1 == ce2 ) ) cand forall z : tau . Ct


% -----------------------------------------------------------------------------
% Context merge
% -----------------------------------------------------------------------------

  defn RS |- Delta0 merge Delta1 = Delta :: :: ctx_merge :: 'Merge_'
  {{ tex [[RS]] \vdash [[Delta0]] \sqcap [[Delta1]] = [[Delta]] }} by

    -------------------------------------- :: empty
    RS |- rempty merge rempty = rempty

    RS |- Delta0 merge Delta1 = Delta
    --------------------------------------------------------------------------- :: eff
    RS |- Delta0 , x : tau [ eff ] merge Delta1 , x : tau [ eff ] = Delta , x : tau [ eff ]

    RS |- Delta0 merge Delta1 = Delta
    --------------------------------------------------------------------------- :: log
    RS |- Delta0 , x : ce [ log ] merge Delta1 , x : ce [ log ] = Delta , x : ce [ log ]

    RS |- Delta0 merge Delta1 = Delta    u = u0 meet u1
    ---------------------------------------------------------------------------------------------- :: res
    RS |- Delta0 , x : ce @ ce' [ res ( u0 ) ] merge Delta1 , x : ce @ ce' [ res ( u1 ) ] = Delta , x : ce @ ce' [ res ( u ) ]



% -----------------------------------------------------------------------------
% Refined pattern matching
% -----------------------------------------------------------------------------

  defn RS ; G |- q : Pf -| Delta :: :: rpat_match :: 'RPM_'
  {{ tex [[RS]] ; [[G]] \vdash [[q]] : [[Pf]] \dashv [[Delta]] }} by

    ---------------------------------------- :: empty
    RS ; G |- rpempty : pfnil -| rempty

    RS ; G , x : tau [ eff ] |- q : app_s id G , x / y Pf -| Delta
    ---------------------------------------------------------------------- :: comp
    RS ; G |- ( x , q ) : y : tau [ eff ] , Pf -| rempty , x : tau [ eff ] , Delta

    RS ; G |- q : Pf -| Delta
    ---------------------------------------------------------------------- :: log
    RS ; G |- ( x , q ) : ce [ log ] , Pf -| rempty , x : ce [ log ] , Delta

    RS ; G |- q : Pf -| Delta
    ---------------------------------------------------------------------------- :: res
    RS ; G |- ( x , q ) : ce @ ce' [ res ] , Pf -| rempty , x : ce @ ce' [ res ( avail ) ] , Delta

    CS = comp RS    CS ; G |- [ spec ] ce ==> pred tau
    RS ; G , x : tau [ spec ] |- q : app_s id G , x / z Pf -| Delta
    --------------------------------------------------------------------------------------------- :: depres
    RS ; G |- ( ( x , w ) , q ) : ( z ) . ce [ res ] , Pf -| rempty , x : tau [ spec ] , w : ce @ x [ res ( avail ) ] , Delta


% -----------------------------------------------------------------------------
% Refined term synthesis
% -----------------------------------------------------------------------------

  defn RS ; Delta |- [ eff ] crt r==> Pf -| Delta' ~~> Ct :: :: rcrt_synth :: 'RCSyn_'
  {{ tex [[RS]] ; [[Delta]] \vdash_{[[eff]]} [[crt]] \Rightarrow [[Pf]] \dashv [[Delta']] \leadsto [[Ct]] }} by

    G = erase Delta    RS ; G |- [ eff ] Pf pfwf
    RS ; Delta |- [ eff ] crt r<== Pf -| Delta' ~~> Ct
    ---------------------------------------------------------- :: annot
    RS ; Delta |- [ eff ] crt : Pf r==> Pf -| Delta' ~~> Ct

    RS |- f : Pf1 -o Pf2 [ eff' ]    eff' <= eff    eff'' = purify eff
    RS ; Delta |- [ eff'' ] rsp : Pf1 -o Pf2 >> Pf -| Delta' ~~> Ct
    -------------------------------------------------------- :: call
    RS ; Delta |- [ eff ] f rsp r==> Pf -| Delta' ~~> Ct

    prim : Pf1 -o Pf2 [ eff' ]    eff' <= eff    eff'' = purify eff
    RS ; Delta |- [ eff'' ] rsp : Pf1 -o Pf2 >> Pf -| Delta' ~~> Ct
    -------------------------------------------------------- :: primapp
    RS ; Delta |- [ eff ] prim rsp r==> Pf -| Delta' ~~> Ct

    RS ; Delta |- rpf r==> take x = ce1 ; ce2 @ ce3 -| Delta' ~~> Ct
    ------------------------------------------------------------------------------------------------------- :: opentake
    RS ; Delta |- [ eff ] open-take rpf r==> x : tau [ spec ] , ce1 @ x [ res ] , ce2 @ ce3 [ res ] , pfnil -| Delta' ~~> Ct

    CS = comp RS    type D ( x , y ) = { Next : a , Done : b } in CS
    G = erase Delta    CS ; G |- [ spec ] ce ==> pred D ( A , B )
    RS ; Delta |- [ pure ] crt1 r<== x : A [ pure ] , ce @ Next x [ res ] , pfnil -| Delta' ~~> Ct
    RS ; Delta' , x : A [ pure ] , y : ce @ Next x [ res ( avail ) ] |- [ impure ] crt2 r<== z : D ( A , B ) [ pure ] , ce @ z [ res ] , pfnil -| Delta' , x : A [ pure ] , y : ce @ Next x [ res ( used ) ] ~~> Ct'
    ------------------------------------------------------------------------------------------------------------------------------------ :: iter
    RS ; Delta |- [ impure ] iter [ ce ] ( q = crt1 ) { crt2 } r==> z : B [ pure ] , ce @ Done z [ res ] , pfnil -| Delta' ~~> Ct cand forall x : A . Ct'


% -----------------------------------------------------------------------------
% Case branch checking
% -----------------------------------------------------------------------------

  defn RS ; Delta |- [ eff ] y : ce is L x -> crt c<== Pf -| Delta' ~~> Ct :: :: case_branch :: 'CBr_'
  {{ tex [[RS]] ; [[Delta]] \vdash_{[[eff]]} [[y]] \mathord{:} [[ce]] \;\mathsf{is}\; [[L]]\,[[x]] \to [[crt]] \Leftarrow [[Pf]] \dashv [[Delta']] \leadsto [[Ct]] }} by

    G = erase Delta    CS = comp RS    CS ; G |- [ eff ] ce ==> D ( tau1 , .. , taui )
    L : tau in D ( tau1 , .. , taui ) in CS
    RS ; Delta , x : tau [ eff ] , y : ce == L x [ log ] |- [ eff ] crt r<== Pf -| Delta' , x : tau [ eff ] , y : ce == L x [ log ] ~~> Ct
    ------------------------------------------------------------------------------------------------------------------- :: branch
    RS ; Delta |- [ eff ] y : ce is L x -> crt c<== Pf -| Delta' ~~> forall x : tau . ce == L x cimp Ct


% -----------------------------------------------------------------------------
% Refined term checking
% -----------------------------------------------------------------------------

  defn RS ; Delta |- [ eff ] crt r<== Pf -| Delta' ~~> Ct :: :: rcrt_check :: 'RCChk_'
  {{ tex [[RS]] ; [[Delta]] \vdash_{[[eff]]} [[crt]] \Leftarrow [[Pf]] \dashv [[Delta']] \leadsto [[Ct]] }} by

    RS ; Delta |- [ eff ] crt1 r==> Pf' -| Delta'  ~~> Ct1
    G = erase Delta'    RS ; G |- q : Pf' -| Delta''
    RS ; Delta' , Delta'' |- [ eff ] crt2 r<== Pf -| Delta''' , Delta'''' ~~> Ct2
    len Delta' = len Delta'''
    len Delta'' = len Delta''''
    zero Delta''''
    Ct'' = close Delta'''' Ct2
    ----------------------------------------------------------------------------- :: let
    RS ; Delta |- [ eff ] let q = crt1 ; crt2 r<== Pf -| Delta''' ~~> Ct1 cand Ct''

    RS ; Delta |- lpf l==> ce -| Delta1 ~~> Ct
    RS ; Delta1 , x : ce [ log ] |- [ eff ] crt r<== Pf -| Delta2 , x : ce [ log ] ~~> Ct'
    ----------------------------------------------------------------------------- :: letlog
    RS ; Delta |- [ eff ] let log x = lpf ; crt r<== Pf -| Delta2 ~~> Ct cand ( ce cimp Ct' )

    RS ; Delta |- rpf r==> ce @ ce' -| Delta1 ~~> Ct
    RS ; Delta1 , x : ce @ ce' [ res ( avail ) ] |- [ eff ] crt r<== Pf -| Delta2 , x : ce @ ce' [ res ( u ) ] ~~> Ct'
    u in_zero
    ----------------------------------------------------------------------------- :: letres
    RS ; Delta |- [ eff ] let res x = rpf ; crt r<== Pf -| Delta2 ~~> Ct cand Ct'

    eff' = purify eff
    G = erase Delta    CS = comp RS    CS ; G |- [ eff' ] ce <== bool
    RS ; Delta , x : ce == true [ log ] |- [ eff' ] crt1 r<== Pf -| Delta1 , x : ce == true [ log ] ~~> Ct1
    RS ; Delta , x : ce == false [ log ] |- [ eff' ] crt2 r<== Pf -| Delta2 , x : ce == false [ log ] ~~> Ct2
    RS |- Delta1 merge Delta2 = Delta'
    ------------------------------------------------------------------------------------------------------------ :: if
    RS ; Delta |- [ eff ] if [ x ] ce then crt1 else crt2 r<== Pf -| Delta' ~~> ( ce == true cimp Ct1 ) cand ( ce == false cimp Ct2 )

    eff' = purify eff
    G = erase Delta    CS = comp RS    CS ; G |- [ eff' ] ce ==> D ( tau1 , .. , taui )
    D ( a1 , .. , ak ) = { L1 : tau'1 | .. | Ln : tau'n } decl_in CS
    RS ; Delta |- [ eff' ] y : ce is L1 x1 -> crt1 c<== Pf -| Delta1 ~~> Ct1 .. RS ; Delta |- [ eff' ] y : ce is Ln xn -> crtn c<== Pf -| Deltan ~~> Ctn
    RS |- ( Delta1 ; .. ; Deltan ) nmerge Delta'
    ------------------------------------------------------------------------------------------------------------------- :: case
    RS ; Delta |- [ eff ] case [ y ] ce of { L1 x1 -> crt1 | .. | Ln xn -> crtn } r<== Pf -| Delta' ~~> Ct1 cand Ctn

    Delta' = affinize Delta
    ------------------------------------------- :: exfalso
    RS ; Delta |- [ eff ] exfalso r<== Pf -| Delta' ~~> Bot

    RS ; Delta |- [ eff ] crt r==> Pf' -| Delta' ~~> Ct
    RS ; Delta' |- Pf' pfeq Pf ~~> Ct'
    --------------------------------------------------------- :: sub
    RS ; Delta |- [ eff ] crt r<== Pf -| Delta' ~~> Ct cand Ct'


% -----------------------------------------------------------------------------
% Spine checking
% -----------------------------------------------------------------------------

  defn RS ; Delta |- [ eff ] rsp : Pf1 -o Pf2 >> Pf -| Delta' ~~> Ct :: :: spine_check :: 'Spine_'
  {{ tex [[RS]] ; [[Delta]] \vdash_{[[eff]]} [[rsp]] : [[Pf1]] \multimap [[Pf2]] \gg [[Pf]] \dashv [[Delta']] \leadsto [[Ct]] }} by

    --------------------------------------------------------------- :: nil
    RS ; Delta |- [ eff ] rspnil : pfnil -o Pf >> Pf -| Delta ~~> Top

    G = erase Delta    CS = comp RS    CS ; G |- [ eff ] ce <== tau
    RS ; Delta |- [ eff ] rsp : app_s id erase Delta , ce / x Pf1 -o app_s id erase Delta , ce / x Pf2 >> Pf -| Delta' ~~> Ct
    -------------------------------------------------------------------------- :: pure
    RS ; Delta |- [ eff ] ce , rsp : x : tau [ pure ] , Pf1 -o Pf2 >> Pf -| Delta' ~~> Ct

    G = erase Delta    CS = comp RS    CS ; G |- [ spec ] ce <== tau
    RS ; Delta |- [ eff ] rsp : app_s id erase Delta , ce / x Pf1 -o app_s id erase Delta , ce / x Pf2 >> Pf -| Delta' ~~> Ct
    -------------------------------------------------------------------------- :: spec
    RS ; Delta |- [ eff ] ce , rsp : x : tau [ spec ] , Pf1 -o Pf2 >> Pf -| Delta' ~~> Ct

    RS ; Delta |- lpf l<== ce -| Delta' ~~> Ct
    RS ; Delta' |- [ eff ] rsp : Pf1 -o Pf2 >> Pf -| Delta'' ~~> Ct'
    ----------------------------------------------------------------------------- :: log
    RS ; Delta |- [ eff ] lpf , rsp : ce [ log ] , Pf1 -o Pf2 >> Pf -| Delta'' ~~> Ct cand Ct'

    RS ; Delta |- rpf r<== ce1 @ ce2 -| Delta' ~~> Ct
    RS ; Delta' |- [ eff ] rsp : Pf1 -o Pf2 >> Pf -| Delta'' ~~> Ct'
    ----------------------------------------------------------------------------- :: res
    RS ; Delta |- [ eff ] rpf , rsp : ce1 @ ce2 [ res ] , Pf1 -o Pf2 >> Pf -| Delta'' ~~> Ct cand Ct'

    RS ; Delta |- rpf r==> ce' @ ce'' -| Delta' ~~> Ct
    RS ; Delta' |- [ eff ] rsp : app_s id erase Delta' , ce'' / y Pf1 -o app_s id erase Delta' , ce'' / y Pf2 >> Pf -| Delta'' ~~> Ct'
    ----------------------------------------------------------------------------- :: depres
    RS ; Delta |- [ eff ] rpf , rsp : ( y ) . ce [ res ] , Pf1 -o Pf2 >> Pf -| Delta'' ~~> ( Ct cand Ct_ce ( ce == ce' ) ) cand Ct'


% -----------------------------------------------------------------------------
% Tuple checking
% -----------------------------------------------------------------------------

  defn RS ; Delta |- [ eff ] rsp t: Pf -| Delta' ~~> Ct :: :: tuple_check :: 'Tup_'
  {{ tex [[RS]] ; [[Delta]] \vdash_{[[eff]]} [[rsp]] : [[Pf]] \dashv [[Delta']] \leadsto [[Ct]] }} by

    --------------------------------------------------------------- :: nil
    RS ; Delta |- [ eff ] rspnil t: pfnil -| Delta ~~> Top

    G = erase Delta    CS = comp RS    CS ; G |- [ eff ] ce <== tau
    RS ; Delta |- [ eff ] rsp t: app_s id erase Delta , ce / x Pf -| Delta' ~~> Ct
    --------------------------------------------------------- :: core
    RS ; Delta |- [ eff ] ce , rsp t: x : tau [ eff ] , Pf -| Delta' ~~> Ct

    RS ; Delta |- lpf l<== ce -| Delta' ~~> Ct
    RS ; Delta' |- [ eff ] rsp t: Pf -| Delta'' ~~> Ct'
    --------------------------------------------------------- :: log
    RS ; Delta |- [ eff ] lpf , rsp t: ce [ log ] , Pf -| Delta'' ~~> Ct cand Ct'

    RS ; Delta |- rpf r<== ce @ ce' -| Delta' ~~> Ct
    RS ; Delta' |- [ eff ] rsp t: Pf -| Delta'' ~~> Ct'
    ------------------------------------------------------------- :: res
    RS ; Delta |- [ eff ] rpf , rsp t: ce @ ce' [ res ] , Pf -| Delta'' ~~> Ct cand Ct'

    RS ; Delta |- rpf r==> ce' @ ce'' -| Delta' ~~> Ct
    RS ; Delta' |- [ eff ] rsp t: app_s id erase Delta' , ce'' / y Pf -| Delta'' ~~> Ct'
    ------------------------------------------------------------- :: depres
    RS ; Delta |- [ eff ] rpf , rsp t: ( y ) . ce [ res ] , Pf -| Delta'' ~~> ( Ct cand Ct_ce ( ce == ce' ) ) cand Ct'


% -----------------------------------------------------------------------------
% Refined program typing
% -----------------------------------------------------------------------------

  defn RS |- rprog -| RS' ~~> Ct :: :: rprog :: 'RProg_'
  {{ tex [[RS]] \vdash [[rprog]] \dashv [[RS']] \leadsto [[Ct]] }} by

    RS ; rempty |- [ eff ] crt r<== Pf -| Delta' ~~> Ct
    ------------------------------------------------------- :: main
    RS |- main : Pf [ eff ] = crt -| RS ~~> Ct

    CS = comp RS    CS |- sort D ( a1 , .. , ai ) = { L1 : tau1 | .. | Ln : taun } sort_ok
    RS , sort D ( a1 , .. , ai ) = { L1 : tau1 | .. | Ln : taun } |- rprog -| RS' ~~> Ct
    -------------------------------------------------------------------------------------- :: sortdecl
    RS |- sort D ( a1 , .. , ai ) = { L1 : tau1 | .. | Ln : taun } rprog -| RS' ~~> Ct

    CS = comp RS    CS |- type D ( a1 , .. , ai ) = { L1 : A1 | .. | Ln : An } type_ok
    RS , type D ( a1 , .. , ai ) = { L1 : A1 | .. | Ln : An } |- rprog -| RS' ~~> Ct
    -------------------------------------------------------------------------------------- :: typedecl
    RS |- type D ( a1 , .. , ai ) = { L1 : A1 | .. | Ln : An } rprog -| RS' ~~> Ct

    CS = comp RS    CS ; empty , x : A [ pure ] |- [ pure ] ce <== B
    RS , fun f ( x : A ) -> B [ pure ] = ce |- rprog -| RS' ~~> Ct
    --------------------------------------------------------------------------- :: purefun
    RS |- fun f ( x : A ) -> B [ pure ] = ce rprog -| RS' ~~> Ct

    CS = comp RS    CS , f : A -> B [ impure ] ; empty , x : A [ pure ] |- [ impure ] ce <== B
    RS , f : A -> B [ impure ] |- rprog -| RS' ~~> Ct
    ------------------------------------------------------------------------------------------------- :: impurefun
    RS |- fun f ( x : A ) -> B [ impure ] = ce rprog -| RS' ~~> Ct

    CS = comp RS    CS , f : tau -> tau' [ spec ] ; empty , x : tau [ spec ] |- [ spec ] ce <== tau'
    RS , fun f ( x : tau ) -> tau' [ spec ] = ce |- rprog -| RS' ~~> Ct
    ------------------------------------------------------------------------------------------------- :: specfun
    RS |- fun f ( x : tau ) -> tau' [ spec ] = ce rprog -| RS' ~~> Ct

    RS |- Pf1 -o Pf2 [ pure ] rfwf
    RS ; empty |- q : Pf1 -| Delta
    RS ; Delta |- [ pure ] crt r<== Pf2 -| Delta' ~~> Ct
    RS , f : Pf1 -o Pf2 [ pure ] |- rprog -| RS' ~~> Ct'
    --------------------------------------------------------------------------- :: purerefined
    RS |- fun f ( q ) : Pf1 -o Pf2 [ pure ] = crt rprog -| RS' ~~> Ct cand Ct'

    RS |- Pf1 -o Pf2 [ impure ] rfwf
    RS ; empty |- q : Pf1 -| Delta
    RS , f : Pf1 -o Pf2 [ impure ] ; Delta |- [ impure ] crt r<== Pf2 -| Delta' ~~> Ct
    RS , f : Pf1 -o Pf2 [ impure ] |- rprog -| RS' ~~> Ct'
    --------------------------------------------------------------------------- :: impurerefined
    RS |- fun f ( q ) : Pf1 -o Pf2 [ impure ] = crt rprog -| RS' ~~> Ct cand Ct'

    RS |- Pf1 -o Pf2 [ spec ] rfwf
    RS ; empty |- q : Pf1 -| Delta
    RS , f : Pf1 -o Pf2 [ spec ] ; Delta |- [ spec ] crt r<== Pf2 -| Delta' ~~> Ct
    RS , f : Pf1 -o Pf2 [ spec ] |- rprog -| RS' ~~> Ct'
    --------------------------------------------------------------------------- :: specrefined
    RS |- fun f ( q ) : Pf1 -o Pf2 [ spec ] = crt rprog -| RS' ~~> Ct cand Ct'


% -----------------------------------------------------------------------------
% N-ary context merge
% -----------------------------------------------------------------------------

  defn RS |- ctxlist nmerge Delta :: :: nary_merge :: 'NMerge_'
  {{ tex [[RS]] \vdash \sqcap [[ctxlist]] = [[Delta]] }} by

    --------------------------------------- :: base
    RS |- Delta0 ; clnil nmerge Delta0

    RS |- Delta0 merge Delta1 = Delta'    RS |- ( Delta' ; ctxlist ) nmerge Delta
    --------------------------------------------------------------------------- :: step
    RS |- ( Delta0 ; Delta1 ; ctxlist ) nmerge Delta



