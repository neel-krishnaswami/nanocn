% nanocn: a small language with bidirectional typechecking
% Merged spec: unified expression grammars, three-level effects

metavar var, x, y, z, w ::=
metavar label, L, Next, Done ::=
metavar lit ::=
metavar f ::=
metavar dsort, D ::=
metavar tvar, a, b ::=
indexvar index, i, j, k, n ::=

grammar

terminals :: 'terminals_' ::=
  | ->                                 :: :: arrow     {{ tex \rightarrow }}
  | ~~>                                :: :: leadsto   {{ tex \leadsto }}
  | -->                                :: :: longarrow {{ tex \to }}
  | ||                                 :: :: doublepipe {{ tex \mid }}
  | vjoin                              :: :: vjoin      {{ tex \vee }}
  | @                                  :: :: at         {{ tex \mathord{@} }}
  | -o                                 :: :: lollipop   {{ tex \multimap }}
  | cand                               :: :: cand       {{ tex \wedge }}
  | cimp                               :: :: cimp       {{ tex \Rightarrow }}
  | decl_in                            :: :: decl_in    {{ tex \in }}
  | true                               :: :: true       {{ tex \mathsf{true} }}
  | false                              :: :: false      {{ tex \mathsf{false} }}

blit :: 'BLit_' ::=                                       {{ com boolean literals }}
  | true                               :: :: True
  | false                              :: :: False

eff, eff_b {{ tex \epsilon }} :: 'Eff_' ::=                        {{ com effects }}
  | pure                               :: :: Pure            {{ tex \mathbf{0} }}
  | impure                             :: :: Impure          {{ tex \mathbf{1} }}
  | spec                               :: :: Spec            {{ tex \mathbf{S} }}

kind :: 'Kind_' ::=                                            {{ com kinds }}
  | type                               :: :: Type           {{ tex \mathsf{type} }}
  | sort                               :: :: Sort           {{ tex \mathsf{sort} }}

tau {{ tex \tau }}, A, B, C :: 'Sort_' ::=                 {{ com sorts }}
  | int                                :: :: Int            {{ com integers }} {{ tex \mathsf{Int} }}
  | bool                               :: :: Bool           {{ com booleans }} {{ tex \mathsf{Bool} }}
  | ptr tau'                           :: :: Ptr            {{ com pointer }}  {{ tex \mathsf{Ptr}\;[[tau']] }}
  | ( tau1 , .. , taun )               :: :: Record         {{ com tuple }}
  | D ( tau1 , .. , taun )             :: :: App            {{ com datatype application }}
  | pred tau'                          :: :: Pred           {{ com predicate sort }} {{ tex \mathsf{Pred}\;[[tau']] }}
  | a                                  :: :: TVar           {{ com type variable }}
  | app_s gamma tau                    :: M :: Subst         {{ tex \lbrack [[gamma]] \rbrack [[tau]] }}

AL {{ tex \overline{A} }} :: 'AList_' ::=                          {{ com type lists }}
  | alnil                             :: :: Nil           {{ tex [] }}
  | A ,, AL                           :: :: Cons          {{ tex [[A]] \mathord{::} [[AL]] }}

F :: 'P_' ::=                                              {{ com function signatures }}
  | tau -> tau' [ eff ]                :: :: FunSig   {{ tex [[tau]] \to_{[[eff]]} [[tau']] }}


G {{ tex \Gamma }} :: 'Ctx_' ::=                            {{ com contexts }}
  | empty                              :: :: Empty          {{ tex \cdot }}
  | G , x : tau [ eff ]               :: :: Ext            {{ tex [[G]], [[x]] \mathord{:}_{[[eff]]} [[tau]] }}
  | G , a : kind                       :: :: TVar           {{ tex [[G]], [[a]] \mathord{:} [[kind]] }}
  | G , G'                             :: :: Concat
  | erase Delta                        :: M :: Erase         {{ tex |[[Delta]]| }}

gamma {{ tex \gamma }} :: 'Subst_' ::=                     {{ com explicit substitutions }}
  | nosub                              :: :: Empty          {{ tex \cdot }}
  | gamma , ce1 / x1 , .. , cen / xn  :: :: TermList
  | gamma , tau1 / a1 , .. , taun / an :: :: TypeList
  | id G                               :: M :: Id          {{ tex \mathsf{id}([[G]]) }}
  | gamma ; gamma'                     :: M :: Comp


CS {{ tex \Sigma_c }} :: 'Sig_' ::=                            {{ com core signatures }}
  | noprims                            :: :: Empty    {{ tex \cdot }}
  | CS , f : F                          :: :: Ext
  | CS , fun f ( x : tau ) -> tau' [ eff ] = ce   :: :: FunDef  {{ tex [[CS]], \mathsf{fun}\;[[f]]([[x]] : [[tau]]) \to_{[[eff]]} [[tau']] = [[ce]] }}
  | CS , sort D ( a1 , .. , ai ) = { L1 : tau1 '|' .. '|' Ln : taun }  :: :: Sort  {{ tex [[CS]], \mathsf{sort}\;[[D]](\overline{a}) = \{\overline{L : \tau}\} }}
  | CS , type D ( a1 , .. , ai ) = { L1 : A1 '|' .. '|' Ln : An }  :: :: Type  {{ tex [[CS]], \mathsf{type}\;[[D]](\overline{a}) = \{\overline{L : A}\} }}

SS {{ tex \Sigma_s }} :: 'SSig_' ::=                            {{ com surface signatures }}
  | nosprims                            :: :: Empty    {{ tex \cdot }}
  | SS , f : F                          :: :: Ext
  | SS , fun f : tau -> tau' [ eff ] = { pat1 --> se1 '|' .. '|' patn --> sen }   :: :: FunDef  {{ tex [[SS]], \mathsf{fun}\;[[f]] : [[tau]] \to_{[[eff]]} [[tau']] = \{\overline{[[pat]] \to [[se]]}\} }}
  | SS , sort D ( a1 , .. , ai ) = { L1 : tau1 '|' .. '|' Ln : taun }  :: :: Sort  {{ tex [[SS]], \mathsf{sort}\;[[D]](\overline{a}) = \{\overline{L : \tau}\} }}
  | SS , type D ( a1 , .. , ai ) = { L1 : A1 '|' .. '|' Ln : An }  :: :: Type  {{ tex [[SS]], \mathsf{type}\;[[D]](\overline{a}) = \{\overline{L : A}\} }}

RS {{ tex \Sigma_r }} :: 'RSig_' ::=                            {{ com refined signatures }}
  | norprims                            :: :: Empty    {{ tex \cdot }}
  | RS , f : F                          :: :: Ext
  | RS , fun f ( x : tau ) -> tau' [ eff ] = ce   :: :: FunDef  {{ tex [[RS]], \mathsf{fun}\;[[f]]([[x]] : [[tau]]) \to_{[[eff]]} [[tau']] = [[ce]] }}
  | RS , f : RF                         :: :: RFun
  | RS , sort D ( a1 , .. , ai ) = { L1 : tau1 '|' .. '|' Ln : taun }  :: :: Sort  {{ tex [[RS]], \mathsf{sort}\;[[D]](\overline{a}) = \{\overline{L : \tau}\} }}
  | RS , type D ( a1 , .. , ai ) = { L1 : A1 '|' .. '|' Ln : An }  :: :: Type  {{ tex [[RS]], \mathsf{type}\;[[D]](\overline{a}) = \{\overline{L : A}\} }}

prim :: 'Prim_' ::=                                            {{ com primitives }}
  | Add                                :: :: Add            {{ com addition }}
  | Sub                                :: :: Sub            {{ com subtraction }}
  | Mul                                :: :: Mul            {{ com multiplication }}
  | Div                                :: :: Div            {{ com division }}
  | And                                :: :: And            {{ com conjunction }}
  | Or                                 :: :: Or             {{ com disjunction }}
  | Not                                :: :: Not            {{ com negation }}
  | Lt                                 :: :: Lt             {{ com less than }}
  | Le                                 :: :: Le             {{ com less or equal }}
  | Gt                                 :: :: Gt             {{ com greater than }}
  | Ge                                 :: :: Ge             {{ com greater or equal }}
  | Eq [ A ]                           :: :: Eq             {{ com equality test }}
  | New [ A ]                          :: :: New            {{ com allocate }}
  | Del [ A ]                          :: :: Del            {{ com deallocate }}
  | Get [ A ]                          :: :: Get            {{ com dereference }}
  | Set [ A ]                          :: :: Set            {{ com update }}
  | Own [ A ]                          :: :: Own            {{ com ownership }}



% ===== Core Expressions (merged computation + assertion) =====

ce :: 'CE_' ::=                                               {{ com core expressions }}
  | x                                  :: :: Var
  | lit                                :: :: IntLit         {{ com integer literal }}
  | blit                               :: :: BoolLit        {{ com boolean literal }}
  | let x = ce1 ; ce2                  :: :: Let
  | ( ce1 , .. , cen )                 :: :: Tuple
  | let ( x1 , .. , xn ) = ce1 ; ce2  :: :: LetTuple
  | L ce                               :: :: Inject
  | case ce of { L1 x1 -> ce1 '|' .. '|' Ln xn -> cen }   :: :: Case
  | iter ( x = ce1 ) { ce2 }          :: :: Iter
  | prim ce                            :: :: App
  | if ce1 then ce2 else ce3          :: :: If             {{ com conditional }}
  | ce : tau                            :: :: Annot
  | f ce                               :: :: Call
  | ce1 '==' ce2                       :: :: Eq            {{ tex [[ce1]] \doteq [[ce2]] }}
  | take x = ce1 ; ce2                :: :: Take
  | return ce                          :: :: Return
  | fail                               :: :: Fail           {{ com failure }}
  | ( ce )                             :: :: Paren
  | app_s gamma ce                     :: M :: ExSubst   {{ tex \lbrack [[gamma]] \rbrack [[ce]] }}



% ===== Surface Expressions (merged computation + assertion) =====

se :: 'SE_' ::=                                            {{ com surface expressions }}
  | x                                  :: :: Var
  | lit                                :: :: IntLit         {{ com integer literal }}
  | blit                               :: :: BoolLit        {{ com boolean literal }}
  | let pat = se1 ; se2                :: :: Let
  | ( se1 , .. , sen )                 :: :: Tuple
  | L se                               :: :: Inject
  | case se of { pat1 -> se1 '|' .. '|' patn -> sen }  :: :: Case
  | iter ( pat = se1 ) { se2 }        :: :: Iter
  | prim se                            :: :: App
  | if se1 then se2 else se3          :: :: If             {{ com conditional }}
  | se : tau                            :: :: Annot
  | f se                               :: :: Call
  | se1 '==' se2                       :: :: Eq            {{ tex [[se1]] \doteq [[se2]] }}
  | take pat = se1 ; se2              :: :: Take
  | return se                          :: :: Return
  | fail                               :: :: Fail           {{ com failure }}



% ===== Programs =====

prog :: 'Prog_' ::=                                        {{ com surface programs }}
  | fun f : tau -> tau' [ eff ] = { pat1 --> se1 '|' .. '|' patn --> sen } prog   :: :: FunDecl   {{ tex \mathsf{fun}\;[[f]] : [[tau]] \to_{[[eff]]} [[tau']] = \{\overline{[[pat]] \to [[se]]}\} \quad \ottnt{prog} }}
  | sort D ( a1 , .. , ai ) = { L1 : tau1 '|' .. '|' Ln : taun } prog   :: :: SortDecl
  | type D ( a1 , .. , ai ) = { L1 : A1 '|' .. '|' Ln : An } prog     :: :: TypeDecl
  | main : tau [ eff ] = se                    :: :: Main   {{ tex \mathsf{main} : [[tau]]_{[[eff]]} = [[se]] }}

cprog :: 'CProg_' ::=                                      {{ com core programs }}
  | fun f ( x : tau ) -> tau' [ eff ] = ce cprog   :: :: FunDecl   {{ tex \mathsf{fun}\;[[f]]([[x]] : [[tau]]) \to_{[[eff]]} [[tau']] = [[ce]] \quad \ottnt{cprog} }}
  | sort D ( a1 , .. , ai ) = { L1 : tau1 '|' .. '|' Ln : taun } cprog   :: :: SortDecl
  | type D ( a1 , .. , ai ) = { L1 : A1 '|' .. '|' Ln : An } cprog     :: :: TypeDecl
  | main : tau [ eff ] = ce                    :: :: Main   {{ tex \mathsf{main} : [[tau]]_{[[eff]]} = [[ce]] }}

rprog :: 'RProg_' ::=                                      {{ com refined programs }}
  | sort D ( a1 , .. , ai ) = { L1 : tau1 '|' .. '|' Ln : taun } rprog   :: :: SortDecl
  | type D ( a1 , .. , ai ) = { L1 : A1 '|' .. '|' Ln : An } rprog     :: :: TypeDecl
  | fun f ( x : tau ) -> tau' [ eff ] = ce rprog   :: :: FunDecl   {{ tex \mathsf{fun}\;[[f]]([[x]] : [[tau]]) \to_{[[eff]]} [[tau']] = [[ce]] \quad \ottnt{rprog} }}
  | fun f ( q ) : Pf1 -o Pf2 [ eff ] = crt rprog   :: :: RFunDecl   {{ tex \mathsf{fun}\;[[f]]([[q]]) : [[Pf1]] \multimap [[Pf2]] \; \lbrack [[eff]] \rbrack = [[crt]] \quad \ottnt{rprog} }}
  | main : Pf [ eff ] = crt                    :: :: Main   {{ tex \mathsf{main} : [[Pf]]_{[[eff]]} = [[crt]] }}


% ===== Pattern Matching Infrastructure =====

pat :: 'Pat_' ::=                                          {{ com patterns }}
  | x                                  :: :: Var
  | L pat                              :: :: Con
  | ( pat1 , .. , patn )               :: :: Tuple

binds {{ tex \beta }} :: 'Binds_' ::=                        {{ com pattern bindings }}
  | nobinds                            :: :: Empty          {{ tex \cdot }}
  | pat : tau , binds                  :: :: Cons
  | pat1 : tau1 , .. , patn : taun , binds   :: :: ConsList
  | pat : tau                          :: :: Single

E {{ tex \mathcal{E} }} :: 'ECtx_' ::=                       {{ com evaluation contexts }}
  | hole                              :: :: Hole           {{ tex [\cdot] }}
  | let x = ce ; E                    :: :: Let

scrs {{ tex \overline{y} }} :: 'Scrs_' ::=                   {{ com scrutinee variables }}
  | noscrs                            :: :: Empty          {{ tex \cdot }}
  | y , scrs                          :: :: Cons
  | y1 , .. , yn , scrs               :: :: ConsList

mbranches {{ tex M }} :: 'MB_' ::=                                {{ com match branches }}
  | nobranches                         :: :: Empty          {{ tex \cdot }}
  | binds --> [ G ] [ E ] se || mbranches     :: :: Cons
  | binds --> [ G ] [ E ] se                  :: :: Single


formula :: 'formula_' ::=
  | judgement                           :: :: judgement
  | x : tau [ eff ] in G               :: :: var_in      {{ tex [[x]] \mathord{:}_{[[eff]]} [[tau]] \in [[G]] }}
  | f : tau -> tau' [ eff ] in CS      :: :: proc_in     {{ tex [[f]] \mathord{:} [[tau]] \to_{[[eff]]} [[tau']] \in [[CS]] }}
  | A eqtype                           :: :: eqtype      {{ tex [[A]] \;\mathsf{eqtype} }}
  | sort D ( a1 , .. , ai ) in CS      :: :: sort_decl
  | L : tau rawctor D in CS            :: :: raw_ctor   {{ tex [[L]] \mathord{:} [[tau]] \in \mathrm{ctors}([[D]]) \in [[CS]] }}
  | sort D ( a1 , .. , ak ) = { L1 : tau1 | .. | Ln : taun } in CS   :: :: sort_lookup
  | type D ( a1 , .. , ai ) in CS      :: :: type_decl
  | L : A rawtypector D in CS          :: :: rawtypector   {{ tex [[L]] \mathord{:} [[A]] \in \mathsf{tyctors}([[D]]) \in [[CS]] }}
  | type D ( a1 , .. , ak ) = { L1 : A1 | .. | Ln : An } in CS   :: :: type_lookup
  | type D ( x , y ) = { Next : a , Done : b } in CS   :: :: step_lookup   {{ tex \mathsf{type}\; [[D]]( [[a]], [[b]]) = \{ \mathsf{Next}\mathord{:}[[a]] \mid \mathsf{Done}\mathord{:}[[b]] \} \in [[CS]] }}
  | a : kind in G                       :: :: tvar_in     {{ tex [[a]] \mathord{:} [[kind]] \in [[G]] }}
  | kind <= kind'                      :: :: subkind     {{ tex [[kind]] \leq [[kind']] }}
  | L != L'                            :: :: label_neq   {{ tex [[L]] \neq [[L']] }}
  | mbranches = mk tau { pat1 --> se1 || .. || patn --> sen }  :: :: mk_branches  {{ tex [[mbranches]] = \overline{ pat \mathord{:} [[tau]], \cdot \to [\cdot][\cdot] \, se } }}
  | ce = fill E ce'                    :: :: fill_ctx      {{ tex [[ce]] = [[E]] [ [[ce']] ] }}
  | D != D'                             :: :: dsort_neq  {{ tex [[D]] \neq [[D']] }}
  | x != y                              :: :: var_neq    {{ tex [[x]] \neq [[y]] }}
  | a != b                              :: :: tvar_neq   {{ tex [[a]] \neq [[b]] }}
  | n = k                               :: :: arity_eq   {{ tex [[n]] = [[k]] }}
  | eff = eff1 join eff2                :: :: eff_join   {{ tex [[eff]] = [[eff1]] \vee [[eff2]] }}
  | eff = eff1 join eff2 join eff3     :: :: eff_join3  {{ tex [[eff]] = [[eff1]] \vee [[eff2]] \vee [[eff3]] }}
  | eff = eff1 vjoin .. vjoin effn             :: :: eff_joinlist_nary
  | G = x1 : tau1 [ eff1 ] , .. , xn : taun [ effn ]  :: :: ctx_eq
  | G = a1 : kind1 , .. , ai : kindi  :: :: tvar_ctx_eq  {{ tex [[G]] = \overline{a : k} }}
  | formula1 .. formulan                :: :: dots
  | x : ce [ log ] in Delta          :: :: log_in     {{ tex [[x]] \mathord{:} [[ce]] \; [\mathsf{log}] \in [[Delta]] }}
  | x : ce @ ce' [ res ( u ) ] in Delta  :: :: res_in  {{ tex [[x]] \mathord{:} [[ce]] @ [[ce']] \; [\mathsf{res}([[u]])] \in [[Delta]] }}
  | x : tau [ eff ] in Delta         :: :: rctx_var_in {{ tex [[x]] \mathord{:}_{[[eff]]} [[tau]] \in [[Delta]] }}
  | u in_avail                        :: :: usage_avail {{ tex [[u]] \in \{1, ?\} }}
  | u in_zero                         :: :: usage_zero  {{ tex [[u]] \in \{0, ?\} }}
  | u = u1 meet u2                    :: :: usage_meet  {{ tex [[u]] = [[u1]] \sqcap [[u2]] }}
  | Delta' = affinize Delta           :: :: affinize    {{ tex [[Delta']] = \mathsf{affinize}([[Delta]]) }}
  | zero Delta                        :: :: zero        {{ tex \mathsf{zero}([[Delta]]) }}
  | G = erase Delta                   :: :: erase       {{ tex [[G]] = |[[Delta]]| }}
  | G = bind Pf                       :: :: bind        {{ tex [[G]] = \mathsf{Bind}(\cdot; [[Pf]]) }}
  | Ct = close Delta Ct'              :: :: close       {{ tex [[Ct]] = [[Delta]] \Rightarrow [[Ct']] }}
  | f : tau -> tau' [ eff ] = ce in CS  :: :: fundef_in {{ tex [[f]]([[x]] : [[tau]]) \to_{[[eff]]} [[tau']] = [[ce]] \in [[CS]] }}
  | eff' in_pfeff eff                    :: :: pfeff       {{ tex [[eff']] \in \{\mathbf{S}, \lfloor [[eff]] \rfloor\} }}
  | f : RF in CS                         :: :: rf_in       {{ tex [[f]] \mathord{:} [[RF]] \in [[CS]] }}
  | f : RF in RS                         :: :: rf_in_rs    {{ tex [[f]] \mathord{:} [[RF]] \in [[RS]] }}
  | f : tau -> tau' [ eff ] in RS        :: :: fun_in_rs   {{ tex [[f]] \mathord{:} [[tau]] \to_{[[eff]]} [[tau']] \in [[RS]] }}
  | f : tau -> tau' [ eff ] = ce in RS   :: :: fundef_in_rs {{ tex [[f]]([[x]] : [[tau]]) \to_{[[eff]]} [[tau']] = [[ce]] \in [[RS]] }}
  | len Delta = len Delta'               :: :: rctx_len_eq {{ tex \mathsf{len}([[Delta]]) = \mathsf{len}([[Delta']]) }}
  | A = prod AL                          :: :: prod         {{ tex [[A]] = \mathsf{Prod}([[AL]]) }}
  | prim : RF                              :: :: prim_rf      {{ tex [[prim]] \mathord{:} [[RF]] }}


% ===== Refinement types grammar =====

u :: 'Usage_' ::=                                    {{ com usage flags }}
  | used                             :: :: Used      {{ tex 0 }}
  | avail                            :: :: Avail     {{ tex 1 }}
  | opt                              :: :: Opt       {{ tex \mathord{?} }}

Delta {{ tex \Delta }} :: 'RCtx_' ::=                {{ com refined contexts }}
  | rempty                           :: :: Empty     {{ tex \cdot }}
  | Delta , x : tau [ eff ]         :: :: Ext        {{ tex [[Delta]], [[x]] \mathord{:}_{[[eff]]} [[tau]] }}
  | Delta , x : ce [ log ]          :: :: Log        {{ tex [[Delta]], [[x]] \mathord{:} [[ce]] \; [\mathsf{log}] }}
  | Delta , x : ce @ ce' [ res ( u ) ]  :: :: Res  {{ tex [[Delta]], [[x]] \mathord{:} [[ce]] @ [[ce']] \; [\mathsf{res}([[u]])] }}
  | Delta , Delta'                   :: :: Concat

ctxlist {{ tex \overline{\Delta} }} :: 'CList_' ::=   {{ com context lists }}
  | Delta ; ctxlist                  :: :: Cons
  | clnil                            :: :: Nil        {{ tex \cdot }}
  | ( ctxlist )                      :: :: Paren
  | Delta1 ; .. ; Deltan             :: :: List

Ct {{ tex \mathcal{C} }} :: 'Ct_' ::=               {{ com SMT constraints }}
  | Top                              :: :: Top       {{ tex \top }}
  | Ct1 cand Ct2                     :: :: And       {{ tex [[Ct1]] \wedge [[Ct2]] }}
  | forall x : tau . Ct             :: :: Forall     {{ tex \forall [[x]] \mathord{:} [[tau]]. \, [[Ct]] }}
  | ce cimp Ct                       :: :: Impl      {{ tex [[ce]] \Rightarrow [[Ct]] }}
  | Ct_ce ce                         :: :: Atom      {{ tex [[ce]] }}
  | Bot                              :: :: Bot       {{ tex \bot }}
  | ( Ct )                           :: :: Paren

Pf :: 'Pf_' ::=                                     {{ com proof sorts }}
  | pfnil                            :: :: Nil       {{ tex \cdot }}
  | x : tau [ eff ] , Pf            :: :: Comp       {{ tex [[x]] \mathord{:}_{[[eff]]} [[tau]], [[Pf]] }}
  | ce [ log ] , Pf                  :: :: Log        {{ tex [[ce]] \; [\mathsf{log}], [[Pf]] }}
  | ce @ ce' [ res ] , Pf           :: :: Res        {{ tex [[ce]] @ [[ce']] \; [\mathsf{res}], [[Pf]] }}
  | ( y ) . ce [ res ] , Pf        :: :: DepRes     {{ tex ([[y]]).[[ce]] \; [\mathsf{res}], [[Pf]] }}
  | app_s gamma Pf                  :: M :: ExSubst   {{ tex \lbrack [[gamma]] \rbrack [[Pf]] }}

RF :: 'RF_' ::=                                      {{ com refined function types }}
  | Pf1 -o Pf2 [ eff ]             :: :: Fun         {{ tex [[Pf1]] \multimap [[Pf2]] \; \lbrack [[eff]] \rbrack }}

q :: 'RPat_' ::=                                     {{ com refined patterns }}
  | rpempty                         :: :: Empty       {{ tex () }}
  | ( x , q )                       :: :: Cons
  | ( ( x , y ) , q )              :: :: ConsPair

crt :: 'CRT_' ::=                                    {{ com core refined terms }}
  | let q = crt1 ; crt2            :: :: Let
  | let log x = lpf ; crt          :: :: LetLog       {{ tex \mathsf{let}\;\mathsf{log}\;[[x]] = [[lpf]]; [[crt]] }}
  | let res x = rpf ; crt          :: :: LetRes       {{ tex \mathsf{let}\;\mathsf{res}\;[[x]] = [[rpf]]; [[crt]] }}
  | crt : Pf                        :: :: Annot
  | prim rsp                        :: :: PrimApp
  | f rsp                           :: :: Call
  | ( rsp )                         :: :: Tuple
  | iter [ ce ] ( q = crt1 ) { crt2 }  :: :: Iter
  | if [ x ] ce then crt1 else crt2  :: :: If
  | case [ y ] ce of { L1 x1 -> crt1 '|' .. '|' Ln xn -> crtn }  :: :: Case
  | exfalso                          :: :: Exfalso     {{ tex \mathsf{exfalso} }}
  | open-take rpf                    :: :: OpenTake    {{ tex \mathsf{open\text{-}take}\;[[rpf]] }}

rsp :: 'Spine_' ::=                                  {{ com refined spines }}
  | rspnil                           :: :: Nil        {{ tex \cdot }}
  | ce , rsp                         :: :: Core
  | rpf , rsp                        :: :: Res
  | lpf , rsp                        :: :: Log

lpf :: 'LPf_' ::=                                   {{ com logical proof facts }}
  | x                               :: :: Var
  | auto                            :: :: Auto        {{ tex \mathsf{auto} }}
  | unfold f ( ce )                 :: :: Unfold       {{ tex \mathsf{unfold}\;[[f]]([[ce]]) }}
  | open-ret rpf                    :: :: OpenRet      {{ tex \mathsf{open\text{-}ret}\;[[rpf]] }}
  | lpf : ce                        :: :: Annot

rpf :: 'RPf_' ::=                                    {{ com resource proof facts }}
  | x                               :: :: Var
  | make-ret lpf                    :: :: MakeRet      {{ tex \mathsf{make\text{-}ret}\;[[lpf]] }}
  | make-take crt                   :: :: MakeTake     {{ tex \mathsf{make\text{-}take}\;[[crt]] }}
  | rpf : ce @ ce'                :: :: Annot        {{ tex [[rpf]] : [[ce]] @ [[ce']] }}



% =============================================================================
% Well-formedness, effects, and primitive typing
% =============================================================================

defns Jtype :: '' ::=

  defn kind <= kind' :: :: subkind :: 'SK_'
  {{ tex [[kind]] \leq [[kind']] }} by

    ------------- :: type_type
    type <= type

    ------------- :: type_sort
    type <= sort

    ------------- :: sort_sort
    sort <= sort

  defn CS ; G |- tau : kind :: :: kind_wf :: 'KWf_'
  {{ tex [[CS]] ; [[G]] \vdash [[tau]] \mathord{:} [[kind]] }} by

    --------------------- :: int
    CS ; G |- int : kind

    ---------------------- :: bool
    CS ; G |- bool : kind

    CS ; G |- tau : type
    ---------------------- :: ptr
    CS ; G |- ptr tau : kind

    CS ; G |- tau1 : kind .. CS ; G |- taun : kind
    ------------------------------------------------ :: record
    CS ; G |- ( tau1 , .. , taun ) : kind

    type D ( a1 , .. , ak ) in CS    n = k
    CS ; G |- tau1 : type .. CS ; G |- taun : type
    ------------------------------------------------ :: type_app
    CS ; G |- D ( tau1 , .. , taun ) : type

    sort D ( a1 , .. , ak ) in CS    n = k
    CS ; G |- tau1 : sort .. CS ; G |- taun : sort
    ------------------------------------------------ :: sort_app
    CS ; G |- D ( tau1 , .. , taun ) : sort

    CS ; G |- tau : sort
    ---------------------- :: pred
    CS ; G |- pred tau : sort

    a : kind' in G    kind' <= kind
    -------------------------------- :: tvar
    CS ; G |- a : kind

  defn CS ; G ; D' ( a1 , .. , ai ) |- tau guarded :: :: type_guarded :: 'TWfG_'
  {{ tex [[CS]] ; [[G]] ; [[D']](\overline{a}) \vdash [[tau]] \;\mathsf{guarded} }} by

    ----------------------- :: int
    CS ; G ; D' ( a1 , .. , ai ) |- int guarded

    ------------------------ :: bool
    CS ; G ; D' ( a1 , .. , ai ) |- bool guarded

    CS , type D' ( a1 , .. , ai ) = { } ; G |- tau : type
    ------------------------------------------------------- :: ptr
    CS ; G ; D' ( a1 , .. , ai ) |- ptr tau guarded

    CS ; G ; D' ( a1 , .. , ai ) |- tau1 guarded .. CS ; G ; D' ( a1 , .. , ai ) |- taun guarded
    ---------------------------------------------------------------------------------------------- :: record
    CS ; G ; D' ( a1 , .. , ai ) |- ( tau1 , .. , taun ) guarded

    type D ( b1 , .. , bk ) in CS    n = k    D != D'
    CS ; G |- tau1 : type .. CS ; G |- taun : type
    ----------------------------------------------------------- :: app
    CS ; G ; D' ( a1 , .. , ai ) |- D ( tau1 , .. , taun ) guarded

    a : kind in G
    ----------------------- :: tvar
    CS ; G ; D' ( a1 , .. , ai ) |- a guarded

  defn CS |- sort D ( a1 , .. , ai ) = { L1 : tau1 '|' .. '|' Ln : taun } sort_ok :: :: sort_decl_wf :: 'SDWf_'
  {{ tex [[CS]] \vdash \mathsf{sort}\; [[D]](\overline{a}) = \{\overline{L : \tau}\} \;\mathsf{ok} }} by

    G = a1 : sort , .. , ai : sort
    CS , sort D ( a1 , .. , ai ) = { } ; G |- tau1 : sort .. CS , sort D ( a1 , .. , ai ) = { } ; G |- taun : sort
    ---------------------------------------------------------------------------- :: ok
    CS |- sort D ( a1 , .. , ai ) = { L1 : tau1 | .. | Ln : taun } sort_ok

  defn CS |- type D ( a1 , .. , ai ) = { L1 : A1 '|' .. '|' Ln : An } type_ok :: :: type_decl_wf :: 'TDWf_'
  {{ tex [[CS]] \vdash \mathsf{type}\; [[D]](\overline{a}) = \{\overline{L : A}\} \;\mathsf{ok} }} by

    G = a1 : type , .. , ai : type
    CS ; G ; D ( a1 , .. , ai ) |- A1 guarded .. CS ; G ; D ( a1 , .. , ai ) |- An guarded
    ---------------------------------------------------------------------------- :: ok
    CS |- type D ( a1 , .. , ai ) = { L1 : A1 | .. | Ln : An } type_ok

  defn CS ; G |- gamma : G' :: :: subst_wf :: 'SubWf_'
  {{ tex [[CS]] ; [[G]] \vdash [[gamma]] \mathbin{:} [[G']] }} by

    ----------------------- :: empty
    CS ; G |- nosub : empty

    CS ; G |- gamma : G'    CS ; G |- [ eff ] ce ==> tau
    ------------------------------------------------------ :: term
    CS ; G |- gamma , ce / x : G' , x : tau [ eff ]

    CS ; G |- gamma : G'    CS ; G |- tau : kind
    ----------------------------------------------- :: type
    CS ; G |- gamma , tau / a : G' , a : kind

% =============================================================================
% Substitution definitions
% =============================================================================

  defn gamma = id G :: :: subst_id_def :: 'IdDef_'
  {{ tex [[gamma]] = \mathsf{id}([[G]]) }} by

    -------------------- :: empty
    nosub = id empty

    gamma = id G
    ---------------------------------- :: term
    gamma , x / x = id G , x : tau [ eff ]

    gamma = id G
    ---------------------------------- :: type
    gamma , a / a = id G , a : kind

  defn tau' = app_s gamma tau :: :: sort_subst :: 'SS_'
  {{ tex [[tau']] = \lbrack [[gamma]] \rbrack [[tau]] }} by

    --------------------- :: int
    int = app_s gamma int

    ----------------------- :: bool
    bool = app_s gamma bool

    tau' = app_s gamma tau
    --------------------------------- :: ptr
    ptr tau' = app_s gamma ptr tau

    tau'1 = app_s gamma tau1 .. tau'n = app_s gamma taun
    ------------------------------------------------------ :: record
    ( tau'1 , .. , tau'n ) = app_s gamma ( tau1 , .. , taun )

    tau'1 = app_s gamma tau1 .. tau'n = app_s gamma taun
    -------------------------------------------------------- :: app
    D ( tau'1 , .. , tau'n ) = app_s gamma D ( tau1 , .. , taun )

    tau' = app_s gamma tau
    ------------------------------- :: pred
    pred tau' = app_s gamma pred tau

    ----------------------------- :: tvar_here
    tau = app_s gamma , tau / a  a

    a != b    tau' = app_s gamma b
    ---------------------------------- :: tvar_skip_ty
    tau' = app_s gamma , tau / a  b

    tau' = app_s gamma b
    ---------------------------------- :: tvar_skip_tm
    tau' = app_s gamma , ce / x  b

  defn ce' = app_s gamma ce :: :: term_subst :: 'TS_'
  {{ tex [[ce']] = \lbrack [[gamma]] \rbrack [[ce]] }} by

    ----------------------------- :: var_here
    ce = app_s gamma , ce / x  x

    x != y    ce' = app_s gamma x
    ---------------------------------- :: var_skip_tm
    ce' = app_s gamma , ce / y  x

    ce' = app_s gamma x
    ---------------------------------- :: var_skip_ty
    ce' = app_s gamma , tau / a  x

    ----------------------- :: intlit
    lit = app_s gamma lit

    ------------------------- :: boollit
    blit = app_s gamma blit

    ce'1 = app_s gamma ce1    ce'2 = app_s gamma , x / x ce2
    ----------------------------------------------------------------- :: let
    let x = ce'1 ; ce'2 = app_s gamma let x = ce1 ; ce2

    ce'1 = app_s gamma ce1 .. ce'n = app_s gamma cen
    -------------------------------------------------------- :: tuple
    ( ce'1 , .. , ce'n ) = app_s gamma ( ce1 , .. , cen )

    ce'1 = app_s gamma ce1    ce'2 = app_s gamma , x1 / x1 , .. , xn / xn ce2
    ------------------------------------------------------------------------------- :: lettuple
    let ( x1 , .. , xn ) = ce'1 ; ce'2 = app_s gamma let ( x1 , .. , xn ) = ce1 ; ce2

    ce' = app_s gamma ce
    ----------------------------- :: inject
    L ce' = app_s gamma L ce

    ce' = app_s gamma ce    ce'1 = app_s gamma , x1 / x1 ce1 .. ce'n = app_s gamma , xn / xn cen
    -------------------------------------------------------------------------------------------------- :: case
    case ce' of { L1 x1 -> ce'1 | .. | Ln xn -> ce'n } = app_s gamma case ce of { L1 x1 -> ce1 | .. | Ln xn -> cen }

    ce'1 = app_s gamma ce1    ce'2 = app_s gamma , x / x ce2
    ----------------------------------------------------------------- :: iter
    iter ( x = ce'1 ) { ce'2 } = app_s gamma iter ( x = ce1 ) { ce2 }

    ce' = app_s gamma ce
    ------------------------------ :: prim
    prim ce' = app_s gamma prim ce

    ce'1 = app_s gamma ce1    ce'2 = app_s gamma ce2    ce'3 = app_s gamma ce3
    ----------------------------------------------------------------------------- :: if
    if ce'1 then ce'2 else ce'3 = app_s gamma if ce1 then ce2 else ce3

    ce' = app_s gamma ce    tau' = app_s gamma tau
    ------------------------------------------------- :: annot
    ce' : tau' = app_s gamma ce : tau

    ce' = app_s gamma ce
    ------------------------------ :: call
    f ce' = app_s gamma f ce

    ce'1 = app_s gamma ce1    ce'2 = app_s gamma ce2
    ---------------------------------------------------- :: eq
    ce'1 == ce'2 = app_s gamma ce1 == ce2

    ce'1 = app_s gamma ce1    ce'2 = app_s gamma , x / x ce2
    ----------------------------------------------------------------- :: take
    take x = ce'1 ; ce'2 = app_s gamma take x = ce1 ; ce2

    ce' = app_s gamma ce
    ---------------------------------- :: return
    return ce' = app_s gamma return ce

  defn Pf' = app_s gamma Pf :: :: pf_subst :: 'PS_'
  {{ tex [[Pf']] = \lbrack [[gamma]] \rbrack [[Pf]] }} by

    ----------------------------- :: nil
    pfnil = app_s gamma pfnil

    tau' = app_s gamma tau    Pf' = app_s gamma , x / x Pf
    ----------------------------------------------------------- :: comp
    x : tau' [ eff ] , Pf' = app_s gamma x : tau [ eff ] , Pf

    ce' = app_s gamma ce    Pf' = app_s gamma Pf
    ------------------------------------------------- :: log
    ce' [ log ] , Pf' = app_s gamma ce [ log ] , Pf

    ce'1 = app_s gamma ce1    ce'2 = app_s gamma ce2    Pf' = app_s gamma Pf
    ----------------------------------------------------------------------------- :: res
    ce'1 @ ce'2 [ res ] , Pf' = app_s gamma ce1 @ ce2 [ res ] , Pf

    ce' = app_s gamma , y / y ce    Pf' = app_s gamma Pf
    ----------------------------------------------------------- :: depres
    ( y ) . ce' [ res ] , Pf' = app_s gamma ( y ) . ce [ res ] , Pf

  defn gamma'' = gamma ; gamma' :: :: subst_comp_def :: 'CompDef_'
  {{ tex [[gamma'']] = [[gamma]] \mathbin{;} [[gamma']] }} by

    --------------------- :: empty
    nosub = gamma ; nosub

    gamma'' = gamma ; gamma'    ce' = app_s gamma ce
    ---------------------------------------------------- :: term
    gamma'' , ce' / x = gamma ; gamma' , ce / x

    gamma'' = gamma ; gamma'    tau' = app_s gamma tau
    ---------------------------------------------------- :: type
    gamma'' , tau' / a = gamma ; gamma' , tau / a

  defn A eqtype :: :: eqtype :: 'EqTy_'
  {{ tex [[A]] \;\mathsf{eqtype} }} by

    ---------- :: int
    int eqtype

    ----------- :: bool
    bool eqtype

    ------------- :: ptr
    ptr A eqtype

  defn eff <= eff' :: :: subeff :: 'Sub_'
  {{ tex [[eff]] \leq [[eff']] }} by

    ---------- :: pure_pure
    pure <= pure

    ------------- :: pure_impure
    pure <= impure

    --------------- :: impure_impure
    impure <= impure

    ------------- :: pure_spec
    pure <= spec

    ------------- :: spec_spec
    spec <= spec

  defn eff' = purify eff :: :: purify :: 'Pur_'
  {{ tex [[eff']] = \lfloor [[eff]] \rfloor }} by

    -------------------- :: pure
    pure = purify pure

    -------------------- :: impure
    pure = purify impure

    -------------------- :: spec
    spec = purify spec

  defn eff = eff1 join eff2 :: :: eff_join :: 'Join_'
  {{ tex [[eff]] = [[eff1]] \vee [[eff2]] }} by

    ---------- :: refl
    eff = eff join eff

    ------------- :: pure_impure
    impure = pure join impure

    ------------- :: impure_pure
    impure = impure join pure

    ------------- :: pure_spec
    spec = pure join spec

    ------------- :: spec_pure
    spec = spec join pure


  defn prim : tau -> tau' [ eff ] :: :: prim_type :: 'PT_'
  {{ tex [[prim]] \mathord{:} [[tau]] \to_{[[eff]]} [[tau']] }} by

    ----------------------------------- :: add
    Add : ( int , int ) -> int [ pure ]

    ----------------------------------- :: sub
    Sub : ( int , int ) -> int [ pure ]

    ----------------------------------- :: mul
    Mul : ( int , int ) -> int [ pure ]

    ------------------------------------- :: div
    Div : ( int , int ) -> int [ impure ]

    --------------------------------------- :: and
    And : ( bool , bool ) -> bool [ pure ]

    --------------------------------------- :: or
    Or : ( bool , bool ) -> bool [ pure ]

    ----------------------------- :: not
    Not : bool -> bool [ pure ]

    ------------------------------------ :: lt
    Lt : ( int , int ) -> bool [ pure ]

    ------------------------------------ :: le
    Le : ( int , int ) -> bool [ pure ]

    ------------------------------------ :: gt
    Gt : ( int , int ) -> bool [ pure ]

    ------------------------------------ :: ge
    Ge : ( int , int ) -> bool [ pure ]

    A eqtype
    ------------------------------------------- :: eq
    Eq [ A ] : ( A , A ) -> bool [ pure ]

    ---------------------------------------- :: new
    New [ A ] : A -> ptr A [ impure ]

    ------------------------------------------ :: del
    Del [ A ] : ptr A -> ( ) [ impure ]

    -------------------------------------- :: get
    Get [ A ] : ptr A -> A [ impure ]

    -------------------------------------------------- :: set
    Set [ A ] : ( ptr A , A ) -> ( ) [ impure ]

    ---------------------------------------- :: own
    Own [ A ] : ptr A -> pred ( A ) [ spec ]


