% nanocn: a small language with bidirectional typechecking
% Merged spec: unified expression grammars, three-level effects

metavar var, x, y, z ::=
metavar label, L, Next, Done ::=
metavar lit ::=
metavar blit ::=
metavar f ::=
metavar dsort, D ::=
metavar tvar, a, b ::=
indexvar index, i, j, k, n ::=

grammar

terminals :: 'terminals_' ::=
  | ->                                 :: :: arrow     {{ tex \rightarrow }}
  | ~~>                                :: :: leadsto   {{ tex \leadsto }}
  | -->                                :: :: longarrow {{ tex \to }}
  | ||                                 :: :: doublepipe {{ tex \mid }}

A, B, C :: 'T_' ::=                                        {{ com types }}
  | int                                :: :: Int            {{ com integers }} {{ tex \mathsf{int} }}
  | bool                               :: :: Bool           {{ com booleans }} {{ tex \mathsf{bool} }}
  | ptr A                              :: :: Ptr            {{ com pointer }}  {{ tex \mathsf{ptr}\;[[A]] }}
  | ( A1 , .. , An )                   :: :: Record         {{ com record }}
  | D ( A1 , .. , An )                 :: :: App            {{ com datatype application }}
  | a                                  :: :: TVar           {{ com type variable }}

eff, eff_b {{ tex \epsilon }} :: 'Eff_' ::=                        {{ com effects }}
  | pure                               :: :: Pure            {{ tex \mathbf{0} }}
  | impure                             :: :: Impure          {{ tex \mathbf{1} }}
  | spec                               :: :: Spec            {{ tex \mathbf{S} }}

tau {{ tex \tau }} :: 'Sort_' ::=                          {{ com sorts }}
  | int                                :: :: Int            {{ com integers }} {{ tex \mathsf{int} }}
  | bool                               :: :: Bool           {{ com booleans }} {{ tex \mathsf{bool} }}
  | ptr tau'                           :: :: Ptr            {{ com pointer }}  {{ tex \mathsf{ptr}\;[[tau']] }}
  | ( tau1 , .. , taun )               :: :: Record         {{ com tuple }}
  | D ( tau1 , .. , taun )             :: :: App            {{ com datasort application }}
  | pred tau'                          :: :: Pred           {{ com predicate sort }} {{ tex \mathsf{pred}\;[[tau']] }}
  | a                                  :: :: TVar           {{ com type variable }}

F :: 'P_' ::=                                              {{ com function signatures }}
  | tau -> tau' [ eff ]                :: :: FunSig   {{ tex [[tau]] \to_{[[eff]]} [[tau']] }}


G {{ tex \Gamma }} :: 'Ctx_' ::=                            {{ com contexts }}
  | empty                              :: :: Empty          {{ tex \cdot }}
  | G , x : tau [ eff ]               :: :: Ext            {{ tex [[G]], [[x]] \mathord{:}_{[[eff]]} [[tau]] }}
  | G , G'                             :: :: Concat


CS {{ tex \Sigma_c }} :: 'Sig_' ::=                            {{ com core signatures }}
  | noprims                            :: :: Empty    {{ tex \cdot }}
  | CS , f : F                          :: :: Ext
  | CS , fun f ( x : tau ) -> tau' [ eff ] = ce   :: :: FunDef  {{ tex [[CS]], \mathsf{fun}\;[[f]]([[x]] : [[tau]]) \to_{[[eff]]} [[tau']] = [[ce]] }}
  | CS , sort D ( a1 , .. , ai ) = { L1 : tau1 '|' .. '|' Ln : taun }  :: :: Sort  {{ tex [[CS]], \mathsf{sort}\;[[D]](\overline{a}) = \{\overline{L : \tau}\} }}
  | CS , type D ( a1 , .. , ai ) = { L1 : A1 '|' .. '|' Ln : An }  :: :: Type  {{ tex [[CS]], \mathsf{type}\;[[D]](\overline{a}) = \{\overline{L : A}\} }}

SS {{ tex \Sigma_s }} :: 'SSig_' ::=                            {{ com surface signatures }}
  | nosprims                            :: :: Empty    {{ tex \cdot }}
  | SS , f : F                          :: :: Ext
  | SS , fun f : tau -> tau' [ eff ] = { pat1 --> se1 '|' .. '|' patn --> sen }   :: :: FunDef  {{ tex [[SS]], \mathsf{fun}\;[[f]] : [[tau]] \to_{[[eff]]} [[tau']] = \{\overline{[[pat]] \to [[se]]}\} }}
  | SS , sort D ( a1 , .. , ai ) = { L1 : tau1 '|' .. '|' Ln : taun }  :: :: Sort  {{ tex [[SS]], \mathsf{sort}\;[[D]](\overline{a}) = \{\overline{L : \tau}\} }}
  | SS , type D ( a1 , .. , ai ) = { L1 : A1 '|' .. '|' Ln : An }  :: :: Type  {{ tex [[SS]], \mathsf{type}\;[[D]](\overline{a}) = \{\overline{L : A}\} }}

Phi {{ tex \Phi }} :: 'TVCtx_' ::=                             {{ com type variable contexts }}
  | notvs                              :: :: Empty          {{ tex \cdot }}
  | Phi , a                            :: :: Ext
  | a1 , .. , ai                       :: :: List           {{ tex \overline{a} }}

prim :: 'Prim_' ::=                                            {{ com primitives }}
  | Add                                :: :: Add            {{ com addition }}
  | Sub                                :: :: Sub            {{ com subtraction }}
  | Mul                                :: :: Mul            {{ com multiplication }}
  | Div                                :: :: Div            {{ com division }}
  | And                                :: :: And            {{ com conjunction }}
  | Or                                 :: :: Or             {{ com disjunction }}
  | Not                                :: :: Not            {{ com negation }}
  | Eq [ A ]                           :: :: Eq             {{ com equality test }}
  | New [ A ]                          :: :: New            {{ com allocate }}
  | Del [ A ]                          :: :: Del            {{ com deallocate }}
  | Get [ A ]                          :: :: Get            {{ com dereference }}
  | Set [ A ]                          :: :: Set            {{ com update }}


% ===== Core Expressions (merged computation + assertion) =====

ce :: 'CE_' ::=                                               {{ com core expressions }}
  | x                                  :: :: Var
  | lit                                :: :: IntLit         {{ com integer literal }}
  | blit                               :: :: BoolLit        {{ com boolean literal }}
  | let x = ce1 ; ce2                  :: :: Let
  | ( ce1 , .. , cen )                 :: :: Tuple
  | let ( x1 , .. , xn ) = ce1 ; ce2  :: :: LetTuple
  | L ce                               :: :: Inject
  | case ce of { L1 x1 -> ce1 '|' .. '|' Ln xn -> cen }   :: :: Case
  | iter ( x = ce1 ) { ce2 }          :: :: Iter
  | prim ce                            :: :: App
  | if ce1 then ce2 else ce3          :: :: If             {{ com conditional }}
  | ce : tau [ eff ]                   :: :: Annot
  | f ce                               :: :: Call
  | ce1 '==' ce2                       :: :: Eq            {{ tex [[ce1]] \doteq [[ce2]] }}
  | ce1 '&&' ce2                       :: :: And           {{ tex [[ce1]] \wedge [[ce2]] }}
  | not ce                             :: :: Not           {{ tex \neg [[ce]] }}
  | Own [ tau ]                        :: :: Own           {{ tex \mathsf{Own}_{[[tau]]} }}
  | take x = ce1 ; ce2                :: :: Take
  | return ce                          :: :: Return



% ===== Surface Expressions (merged computation + assertion) =====

se :: 'SE_' ::=                                            {{ com surface expressions }}
  | x                                  :: :: Var
  | lit                                :: :: IntLit         {{ com integer literal }}
  | blit                               :: :: BoolLit        {{ com boolean literal }}
  | let pat = se1 ; se2                :: :: Let
  | ( se1 , .. , sen )                 :: :: Tuple
  | L se                               :: :: Inject
  | case se of { pat1 -> se1 '|' .. '|' patn -> sen }  :: :: Case
  | iter ( pat = se1 ) { se2 }        :: :: Iter
  | prim se                            :: :: App
  | if se1 then se2 else se3          :: :: If             {{ com conditional }}
  | se : tau [ eff ]                   :: :: Annot
  | f se                               :: :: Call
  | se1 '==' se2                       :: :: Eq            {{ tex [[se1]] \doteq [[se2]] }}
  | se1 '&&' se2                       :: :: And           {{ tex [[se1]] \wedge [[se2]] }}
  | not se                             :: :: Not           {{ tex \neg [[se]] }}
  | take pat = se1 ; se2              :: :: Take
  | return se                          :: :: Return



% ===== Programs =====

prog :: 'Prog_' ::=                                        {{ com surface programs }}
  | fun f : tau -> tau' [ eff ] = { pat1 --> se1 '|' .. '|' patn --> sen } prog   :: :: FunDecl   {{ tex \mathsf{fun}\;[[f]] : [[tau]] \to_{[[eff]]} [[tau']] = \{\overline{[[pat]] \to [[se]]}\} \quad \ottnt{prog} }}
  | sort D ( a1 , .. , ai ) = { L1 : tau1 '|' .. '|' Ln : taun } prog   :: :: SortDecl
  | type D ( a1 , .. , ai ) = { L1 : A1 '|' .. '|' Ln : An } prog     :: :: TypeDecl
  | main : tau [ eff ] = se                    :: :: Main   {{ tex \mathsf{main} : [[tau]]_{[[eff]]} = [[se]] }}

cprog :: 'CProg_' ::=                                      {{ com core programs }}
  | fun f ( x : tau ) -> tau' [ eff ] = ce cprog   :: :: FunDecl   {{ tex \mathsf{fun}\;[[f]]([[x]] : [[tau]]) \to_{[[eff]]} [[tau']] = [[ce]] \quad \ottnt{cprog} }}
  | sort D ( a1 , .. , ai ) = { L1 : tau1 '|' .. '|' Ln : taun } cprog   :: :: SortDecl
  | type D ( a1 , .. , ai ) = { L1 : A1 '|' .. '|' Ln : An } cprog     :: :: TypeDecl
  | main : tau [ eff ] = ce                    :: :: Main   {{ tex \mathsf{main} : [[tau]]_{[[eff]]} = [[ce]] }}


% ===== Pattern Matching Infrastructure =====

pat :: 'Pat_' ::=                                          {{ com patterns }}
  | x                                  :: :: Var
  | L pat                              :: :: Con
  | ( pat1 , .. , patn )               :: :: Tuple

binds {{ tex \beta }} :: 'Binds_' ::=                        {{ com pattern bindings }}
  | nobinds                            :: :: Empty          {{ tex \cdot }}
  | pat : tau , binds                  :: :: Cons
  | pat1 : tau1 , .. , patn : taun , binds   :: :: ConsList
  | pat : tau                          :: :: Single

E {{ tex \mathcal{E} }} :: 'ECtx_' ::=                       {{ com evaluation contexts }}
  | hole                              :: :: Hole           {{ tex [\cdot] }}
  | let x = ce ; E                    :: :: Let

scrs {{ tex \overline{y} }} :: 'Scrs_' ::=                   {{ com scrutinee variables }}
  | noscrs                            :: :: Empty          {{ tex \cdot }}
  | y , scrs                          :: :: Cons
  | y1 , .. , yn , scrs               :: :: ConsList

mbranches {{ tex M }} :: 'MB_' ::=                                {{ com match branches }}
  | nobranches                         :: :: Empty          {{ tex \cdot }}
  | binds --> [ G ] [ E ] se || mbranches     :: :: Cons
  | binds --> [ G ] [ E ] se                  :: :: Single


formula :: 'formula_' ::=
  | judgement                           :: :: judgement
  | x : tau [ eff ] in G               :: :: var_in      {{ tex [[x]] \mathord{:}_{[[eff]]} [[tau]] \in [[G]] }}
  | f : F in CS                        :: :: proc_in     {{ tex [[f]] \mathord{:} [[F]] \in [[CS]] }}
  | A eqtype                           :: :: eqtype      {{ tex [[A]] \;\mathsf{eqtype} }}
  | sort D ( a1 , .. , ai ) in CS      :: :: sort_decl
  | L : tau rawctor D in CS            :: :: raw_ctor   {{ tex [[L]] \mathord{:} [[tau]] \in \mathrm{ctors}([[D]]) \in [[CS]] }}
  | tau = subst tau1 / a1 , .. , taui / ai in tau'   :: :: subst_eq
  | sort D ( a1 , .. , ak ) = { L1 : tau1 | .. | Ln : taun } in CS   :: :: sort_lookup
  | type D ( a1 , .. , ai ) in CS      :: :: type_decl
  | L : A rawtypector D in CS          :: :: rawtypector   {{ tex [[L]] \mathord{:} [[A]] \in \mathsf{tyctors}([[D]]) \in [[CS]] }}
  | A = subst A1 / a1 , .. , Ai / ai in A'   :: :: type_subst_eq
  | type D ( a1 , .. , ak ) = { L1 : A1 | .. | Ln : An } in CS   :: :: type_lookup
  | type D ( x , y ) = { Next : a , Done : b } in CS   :: :: step_lookup   {{ tex \mathsf{type}\; [[D]]( [[a]], [[b]]) = \{ \mathsf{Next}\mathord{:}[[a]] \mid \mathsf{Done}\mathord{:}[[b]] \} \in [[CS]] }}
  | a in Phi                            :: :: tvar_in     {{ tex [[a]] \in [[Phi]] }}
  | L != L'                            :: :: label_neq   {{ tex [[L]] \neq [[L']] }}
  | mbranches = mk tau { pat1 --> se1 || .. || patn --> sen }  :: :: mk_branches  {{ tex [[mbranches]] = \overline{ pat \mathord{:} [[tau]], \cdot \to [\cdot][\cdot] \, se } }}
  | ce = fill E ce'                    :: :: fill_ctx      {{ tex [[ce]] = [[E]] [ [[ce']] ] }}
  | D != D'                             :: :: dsort_neq  {{ tex [[D]] \neq [[D']] }}
  | n = k                               :: :: arity_eq   {{ tex [[n]] = [[k]] }}
  | formula1 .. formulan                :: :: dots

subrules
  A <:: tau


% =============================================================================
% Well-formedness, effects, and primitive typing
% =============================================================================

defns Jtype :: '' ::=

  defn CS ; Phi |- A wf :: :: type_wf :: 'TWf_'
  {{ tex [[CS]] ; [[Phi]] \vdash [[A]] \;\mathsf{wf} }} by

    ------------- :: int
    CS ; Phi |- int wf

    -------------- :: bool
    CS ; Phi |- bool wf

    CS ; Phi |- A wf
    ---------------- :: ptr
    CS ; Phi |- ptr A wf

    CS ; Phi |- A1 wf .. CS ; Phi |- An wf
    ---------------------------------------- :: record
    CS ; Phi |- ( A1 , .. , An ) wf

    type D ( a1 , .. , ak ) in CS    n = k
    CS ; Phi |- A1 wf .. CS ; Phi |- An wf
    ---------------------------------------- :: app
    CS ; Phi |- D ( A1 , .. , An ) wf

    a in Phi
    ------------- :: tvar
    CS ; Phi |- a wf

  defn CS ; Phi ; D' |- A guarded :: :: type_guarded :: 'TWfG_'
  {{ tex [[CS]] ; [[Phi]] ; [[D']] \vdash [[A]] \;\mathsf{guarded} }} by

    --------------- :: int
    CS ; Phi ; D' |- int guarded

    ---------------- :: bool
    CS ; Phi ; D' |- bool guarded

    CS ; Phi |- A wf
    ------------------- :: ptr
    CS ; Phi ; D' |- ptr A guarded

    CS ; Phi ; D' |- A1 guarded .. CS ; Phi ; D' |- An guarded
    ----------------------------------------------------------- :: record
    CS ; Phi ; D' |- ( A1 , .. , An ) guarded

    type D ( a1 , .. , ak ) in CS    n = k    D != D'
    CS ; Phi ; D' |- A1 guarded .. CS ; Phi ; D' |- An guarded
    ----------------------------------------------------------- :: app
    CS ; Phi ; D' |- D ( A1 , .. , An ) guarded

    a in Phi
    --------------- :: tvar
    CS ; Phi ; D' |- a guarded

  defn CS |- sort D ( a1 , .. , ai ) = { L1 : tau1 '|' .. '|' Ln : taun } sort_ok :: :: sort_decl_wf :: 'SDWf_'
  {{ tex [[CS]] \vdash \mathsf{sort}\; [[D]](\overline{a}) = \{\overline{L : \tau}\} \;\mathsf{ok} }} by

    CS , sort D ( a1 , .. , ai ) = { L1 : tau1 | .. | Ln : taun } ; a1 , .. , ai |- tau1 wf .. CS , sort D ( a1 , .. , ai ) = { L1 : tau1 | .. | Ln : taun } ; a1 , .. , ai |- taun wf
    ---------------------------------------------------------------------------- :: ok
    CS |- sort D ( a1 , .. , ai ) = { L1 : tau1 | .. | Ln : taun } sort_ok

  defn CS |- type D ( a1 , .. , ai ) = { L1 : A1 '|' .. '|' Ln : An } type_ok :: :: type_decl_wf :: 'TDWf_'
  {{ tex [[CS]] \vdash \mathsf{type}\; [[D]](\overline{a}) = \{\overline{L : A}\} \;\mathsf{ok} }} by

    CS , type D ( a1 , .. , ai ) = { L1 : A1 | .. | Ln : An } ; a1 , .. , ai ; D |- A1 guarded .. CS , type D ( a1 , .. , ai ) = { L1 : A1 | .. | Ln : An } ; a1 , .. , ai ; D |- An guarded
    ---------------------------------------------------------------------------- :: ok
    CS |- type D ( a1 , .. , ai ) = { L1 : A1 | .. | Ln : An } type_ok

  defn CS ; Phi |- tau wf :: :: sort_wf :: 'SWf_'
  {{ tex [[CS]] ; [[Phi]] \vdash [[tau]] \;\mathsf{wf} }} by

    --------------- :: int
    CS ; Phi |- int wf

    ---------------- :: bool
    CS ; Phi |- bool wf

    CS ; Phi |- tau wf
    ------------------- :: ptr
    CS ; Phi |- ptr tau wf

    CS ; Phi |- tau1 wf .. CS ; Phi |- taun wf
    -------------------------------------------- :: record
    CS ; Phi |- ( tau1 , .. , taun ) wf

    sort D ( a1 , .. , ak ) in CS    n = k
    CS ; Phi |- tau1 wf .. CS ; Phi |- taun wf
    -------------------------------------------- :: app
    CS ; Phi |- D ( tau1 , .. , taun ) wf

    CS ; Phi |- tau wf
    ------------------- :: pred
    CS ; Phi |- pred tau wf

    a in Phi
    ------------- :: tvar
    CS ; Phi |- a wf

  defn A eqtype :: :: eqtype :: 'EqTy_'
  {{ tex [[A]] \;\mathsf{eqtype} }} by

    ---------- :: int
    int eqtype

    ----------- :: bool
    bool eqtype

    ------------- :: ptr
    ptr A eqtype

  defn eff <= eff' :: :: subeff :: 'Sub_'
  {{ tex [[eff]] \leq [[eff']] }} by

    ---------- :: pure_pure
    pure <= pure

    ------------- :: pure_impure
    pure <= impure

    --------------- :: impure_impure
    impure <= impure

    ------------- :: pure_spec
    pure <= spec

    ------------- :: spec_spec
    spec <= spec

  defn eff' = purify eff :: :: purify :: 'Pur_'
  {{ tex [[eff']] = \lfloor [[eff]] \rfloor }} by

    -------------------- :: pure
    pure = purify pure

    -------------------- :: impure
    pure = purify impure

    -------------------- :: spec
    spec = purify spec


  defn prim : A -> B [ eff ] :: :: prim_type :: 'PT_'
  {{ tex [[prim]] \mathord{:} [[A]] \to_{[[eff]]} [[B]] }} by

    ----------------------------------- :: add
    Add : ( int , int ) -> int [ pure ]

    ----------------------------------- :: sub
    Sub : ( int , int ) -> int [ pure ]

    ----------------------------------- :: mul
    Mul : ( int , int ) -> int [ pure ]

    ------------------------------------- :: div
    Div : ( int , int ) -> int [ impure ]

    --------------------------------------- :: and
    And : ( bool , bool ) -> bool [ pure ]

    --------------------------------------- :: or
    Or : ( bool , bool ) -> bool [ pure ]

    ----------------------------- :: not
    Not : bool -> bool [ pure ]

    A eqtype
    ------------------------------------------- :: eq
    Eq [ A ] : ( A , A ) -> bool [ pure ]

    ---------------------------------------- :: new
    New [ A ] : A -> ptr A [ impure ]

    ------------------------------------------ :: del
    Del [ A ] : ptr A -> ( ) [ impure ]

    -------------------------------------- :: get
    Get [ A ] : ptr A -> A [ impure ]

    -------------------------------------------------- :: set
    Set [ A ] : ( ptr A , A ) -> ( ) [ impure ]


% =============================================================================
% Core typing (merged computation + assertion)
% =============================================================================

  defn CS ; G |- ce ==> tau [ eff ] :: :: synth :: 'Syn_'
  {{ tex [[CS]] ; [[G]] \vdash_{[[eff]]} [[ce]] \Rightarrow [[tau]] }} by

    ----------------------- :: int
    CS ; G |- lit ==> int [ pure ]

    -------------------------- :: bool
    CS ; G |- blit ==> bool [ pure ]

    x : tau [ eff ] in G
    ----------------------- :: var
    CS ; G |- x ==> tau [ eff ]

    CS ; G |- ce <== tau [ eff ]
    ---------------------------------- :: annot
    CS ; G |- ce : tau [ eff ] ==> tau [ eff ]

    prim : A -> B [ eff ]    CS ; G |- ce <== A [ pure ]
    --------------------------------------------------- :: app
    CS ; G |- prim ce ==> B [ eff ]

    f : F in CS    CS ; G |- ce <== tau [ pure ]
    ---------------------------------------- :: call
    CS ; G |- f ce ==> tau' [ eff ]

    f : tau -> tau' [ spec ] in CS    CS ; G |- ce <== tau [ spec ]
    --------------------------------------------------------------- :: speccall
    CS ; G |- f ce ==> tau' [ spec ]

    f : A -> B [ pure ] in CS    CS ; G |- ce <== A [ spec ]
    -------------------------------------------------------- :: purecall
    CS ; G |- f ce ==> B [ spec ]

    CS ; G |- ce1 ==> A [ eff' ]    CS ; G |- ce2 <== A [ spec ]
    ------------------------------------------------- :: eq
    CS ; G |- ce1 == ce2 ==> bool [ spec ]

    CS ; G |- ce1 <== bool [ spec ]    CS ; G |- ce2 <== bool [ spec ]
    ------------------------------------------------- :: and
    CS ; G |- ce1 && ce2 ==> bool [ spec ]

    CS ; G |- ce <== bool [ spec ]
    ----------------------- :: not
    CS ; G |- not ce ==> bool [ spec ]

    --------------------------------- :: own
    CS ; G |- Own [ tau ] ==> pred tau [ spec ]

    prim : A -> B [ pure ]    CS ; G |- ce <== A [ spec ]
    --------------------------------------------------- :: specapp
    CS ; G |- prim ce ==> B [ spec ]

  defn CS ; G |- ce <== tau [ eff ] :: :: check :: 'Chk_'
  {{ tex [[CS]] ; [[G]] \vdash_{[[eff]]} [[ce]] \Leftarrow [[tau]] }} by

    CS ; G |- ce1 ==> tau [ eff' ]    eff' <= eff    eff_b = purify eff    CS ; G , x : tau [ eff_b ] |- ce2 <== tau' [ eff ]
    -------------------------------------------------------------------------- :: let
    CS ; G |- let x = ce1 ; ce2 <== tau' [ eff ]

    CS ; G |- ce1 <== tau1 [ eff ] .. CS ; G |- cen <== taun [ eff ]
    --------------------------------------------------- :: tuple
    CS ; G |- ( ce1 , .. , cen ) <== ( tau1 , .. , taun ) [ eff ]

    CS ; G |- ce1 ==> ( tau1 , .. , taun ) [ eff' ]    eff' <= eff    CS ; G' |- ce2 <== tau' [ eff ]
    ---------------------------------------------------------------------------------- :: lettuple
    CS ; G |- let ( x1 , .. , xn ) = ce1 ; ce2 <== tau' [ eff ]

    L : tau in D ( tau1 , .. , taui ) in CS    CS ; G |- ce <== tau [ eff ]
    ----------------------------------------------------------------- :: inject
    CS ; G |- L ce <== D ( tau1 , .. , taui ) [ eff ]

    CS ; G |- ce ==> D ( tau1 , .. , taui ) [ eff' ]
    eff' <= eff
    eff_b = purify eff
    D ( a1 , .. , ak ) = { L1 : tau'1 | .. | Ln : tau'n } decl_in CS
    L1 : tau''1 in D ( tau1 , .. , taui ) in CS .. Ln : tau''n in D ( tau1 , .. , taui ) in CS
    CS ; G , x1 : tau''1 [ eff_b ] |- ce1 <== tau [ eff ] .. CS ; G , xn : tau''n [ eff_b ] |- cen <== tau [ eff ]
    ---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------- :: case
    CS ; G |- case ce of { L1 x1 -> ce1 | .. | Ln xn -> cen } <== tau [ eff ]

    CS ; G |- ce1 ==> A [ eff' ]
    type D ( x , y ) = { Next : a , Done : b } in CS
    eff_b = purify impure
    CS ; G , x : A [ eff_b ] |- ce2 <== D ( A , B ) [ impure ]
    impure <= eff
    --------------------------------------------------------------------------------------------------------------------------------------- :: iter
    CS ; G |- iter ( x = ce1 ) { ce2 } <== B [ eff ]

    CS ; G |- ce1 <== bool [ eff ]    CS ; G |- ce2 <== tau [ eff ]    CS ; G |- ce3 <== tau [ eff ]
    ------------------------------------------------------------------------------------- :: if
    CS ; G |- if ce1 then ce2 else ce3 <== tau [ eff ]

    CS ; G |- ce <== tau [ eff ]
    ---------------------------------- :: return
    CS ; G |- return ce <== pred tau [ eff ]

    CS ; G |- ce1 ==> pred tau [ eff' ]    eff' <= eff    eff_b = purify eff    CS ; G , x : tau [ eff_b ] |- ce2 <== pred tau' [ eff ]
    -------------------------------------------------------------------------- :: take
    CS ; G |- take x = ce1 ; ce2 <== pred tau' [ eff ]

    CS ; G |- ce ==> tau [ eff' ]    eff' <= eff
    --------------------------------------- :: sub
    CS ; G |- ce <== tau [ eff ]


% =============================================================================
% Core program typing
% =============================================================================

  defn CS |- cprog :: :: cprog :: 'CProg_'
  {{ tex [[CS]] \vdash [[cprog]] }} by

    CS ; G |- ce <== tau [ eff ]
    ------------------------------------------------------ :: main
    CS |- main : tau [ eff ] = ce

    CS ; G , x : A [ pure ] |- ce <== B [ pure ]
    CS , fun f ( x : A ) -> B [ pure ] = ce |- cprog
    --------------------------------------------------------------------------- :: purefun
    CS |- fun f ( x : A ) -> B [ pure ] = ce cprog

    CS , f : A -> B [ impure ] ; G , x : A [ pure ] |- ce <== B [ impure ]
    CS , f : A -> B [ impure ] |- cprog
    ------------------------------------------------------------------------------------------------- :: impurefun
    CS |- fun f ( x : A ) -> B [ impure ] = ce cprog

    CS , f : tau -> tau' [ spec ] ; G , x : tau [ spec ] |- ce <== tau' [ spec ]
    CS , fun f ( x : tau ) -> tau' [ spec ] = ce |- cprog
    ----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------- :: specfun
    CS |- fun f ( x : tau ) -> tau' [ spec ] = ce cprog

    CS |- sort D ( a1 , .. , ai ) = { L1 : tau1 | .. | Ln : taun } sort_ok
    CS , sort D ( a1 , .. , ai ) = { L1 : tau1 | .. | Ln : taun } |- cprog
    ---------------------------------------------------------------------------- :: sortdecl
    CS |- sort D ( a1 , .. , ai ) = { L1 : tau1 | .. | Ln : taun } cprog

    CS |- type D ( a1 , .. , ai ) = { L1 : A1 | .. | Ln : An } type_ok
    CS , type D ( a1 , .. , ai ) = { L1 : A1 | .. | Ln : An } |- cprog
    ---------------------------------------------------------------------------- :: typedecl
    CS |- type D ( a1 , .. , ai ) = { L1 : A1 | .. | Ln : An } cprog


% =============================================================================
% Constructor lookup (unified sort + type)
% =============================================================================

defns Jcore :: '' ::=

  defn L : tau in D ( tau1 , .. , taui ) in CS :: :: ctor_lookup :: 'Ctor_' by

    sort D ( a1 , .. , ai ) in CS    L : tau' rawctor D in CS    tau = subst tau1 / a1 , .. , taui / ai in tau'
    ---------------------------------------------------------------------------------------------------------- :: sort
    L : tau in D ( tau1 , .. , taui ) in CS

    type D ( a1 , .. , ai ) in CS    L : A' rawtypector D in CS    A = subst A1 / a1 , .. , Ai / ai in A'
    ------------------------------------------------------------------------------------------------------ :: type
    L : A in D ( A1 , .. , Ai ) in CS

  defn D ( a1 , .. , ak ) = { L1 : tau1 '|' .. '|' Ln : taun } decl_in CS :: :: decl_lookup :: 'DL_'
  {{ tex [[D]](\overline{a}) = \{\overline{L : \tau}\} \in [[CS]] }} by

    sort D ( a1 , .. , ak ) = { L1 : tau1 | .. | Ln : taun } in CS
    --------------------------------------------------------------- :: sort
    D ( a1 , .. , ak ) = { L1 : tau1 | .. | Ln : taun } decl_in CS

    type D ( a1 , .. , ak ) = { L1 : A1 | .. | Ln : An } in CS
    --------------------------------------------------------------- :: type
    D ( a1 , .. , ak ) = { L1 : A1 | .. | Ln : An } decl_in CS


% =============================================================================
% Surface elaboration (merged computation + assertion)
% =============================================================================

defns Jelaborate :: '' ::=

  defn CS ; G |- se ==> tau [ eff ] ~~> ce :: :: surf_synth :: 'SurfSyn_'
  {{ tex [[CS]] ; [[G]] \vdash_{[[eff]]} [[se]] \Rightarrow [[tau]] \leadsto [[ce]] }} by

    x : tau [ eff ] in G
    ----------------------- :: var
    CS ; G |- x ==> tau [ eff ] ~~> x

    ----------------------- :: int
    CS ; G |- lit ==> int [ pure ] ~~> lit

    -------------------------- :: bool
    CS ; G |- blit ==> bool [ pure ] ~~> blit

    CS ; G |- se <== tau [ eff ] ~~> ce
    ---------------------------------- :: annot
    CS ; G |- se : tau [ eff ] ==> tau [ eff ] ~~> ce : tau [ eff ]

    prim : A -> B [ eff ]
    CS ; G |- se <== A [ pure ] ~~> ce
    --------------------------------------------------- :: app
    CS ; G |- prim se ==> B [ eff ] ~~> prim ce

    f : F in CS
    CS ; G |- se <== tau [ pure ] ~~> ce
    ---------------------------------------- :: call
    CS ; G |- f se ==> tau' [ eff ] ~~> f ce

    f : tau -> tau' [ spec ] in CS
    CS ; G |- se <== tau [ spec ] ~~> ce
    --------------------------------------------------------------- :: speccall
    CS ; G |- f se ==> tau' [ spec ] ~~> f ce

    f : A -> B [ pure ] in CS
    CS ; G |- se <== A [ spec ] ~~> ce
    --------------------------------------------------------------- :: purecall
    CS ; G |- f se ==> B [ spec ] ~~> f ce

    CS ; G |- se1 ==> A [ eff' ] ~~> ce1
    CS ; G |- se2 <== A [ spec ] ~~> ce2
    ------------------------------------------------- :: eq
    CS ; G |- se1 == se2 ==> bool [ spec ] ~~> ce1 == ce2

    CS ; G |- se1 <== bool [ spec ] ~~> ce1
    CS ; G |- se2 <== bool [ spec ] ~~> ce2
    ------------------------------------------------- :: and
    CS ; G |- se1 && se2 ==> bool [ spec ] ~~> ce1 && ce2

    CS ; G |- se <== bool [ spec ] ~~> ce
    ----------------------- :: not
    CS ; G |- not se ==> bool [ spec ] ~~> not ce

    prim : A -> B [ pure ]
    CS ; G |- se <== A [ spec ] ~~> ce
    --------------------------------------------------- :: specapp
    CS ; G |- prim se ==> B [ spec ] ~~> prim ce

  defn CS ; G |- se <== tau [ eff ] ~~> ce :: :: surf_check :: 'SurfChk_'
  {{ tex [[CS]] ; [[G]] \vdash_{[[eff]]} [[se]] \Leftarrow [[tau]] \leadsto [[ce]] }} by

    CS ; G |- se1 ==> tau [ eff' ] ~~> ce1
    eff' <= eff
    CS ; G |- y , noscrs ; pat : tau --> [ empty ] [ hole ] se2 <== tau' [ eff ] ~~> ce2
    -------------------------------------------------------------------------- :: let
    CS ; G |- let pat = se1 ; se2 <== tau' [ eff ] ~~> let y = ce1 ; ce2

    CS ; G |- se1 <== tau1 [ eff ] ~~> ce1 .. CS ; G |- sen <== taun [ eff ] ~~> cen
    --------------------------------------------------- :: tuple
    CS ; G |- ( se1 , .. , sen ) <== ( tau1 , .. , taun ) [ eff ] ~~> ( ce1 , .. , cen )

    L : tau in D ( tau1 , .. , taui ) in CS
    CS ; G |- se <== tau [ eff ] ~~> ce
    ----------------------------------------------------------------- :: inject
    CS ; G |- L se <== D ( tau1 , .. , taui ) [ eff ] ~~> L ce

    CS ; G |- se ==> tau [ eff' ] ~~> ce'
    eff' <= eff
    mbranches = mk tau { pat1 --> se1 || .. || patn --> sen }
    CS ; G |- y , noscrs ; mbranches <== tau' [ eff ] ~~> ce
    ---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------- :: case
    CS ; G |- case se of { pat1 -> se1 | .. | patn -> sen } <== tau' [ eff ] ~~> let y = ce' ; ce

    CS ; G |- se1 ==> A [ eff' ] ~~> ce1
    eff' <= eff
    type D ( x , y ) = { Next : a , Done : b } in CS
    mbranches = mk A { pat --> se2 }
    CS ; G |- z , noscrs ; mbranches <== D ( A , B ) [ impure ] ~~> ce2
    impure <= eff
    --------------------------------------------------------------------------------------------------------------------------------------- :: iter
    CS ; G |- iter ( pat = se1 ) { se2 } <== B [ eff ] ~~> iter ( z = ce1 ) { ce2 }

    CS ; G |- se1 <== bool [ eff ] ~~> ce1
    CS ; G |- se2 <== tau [ eff ] ~~> ce2
    CS ; G |- se3 <== tau [ eff ] ~~> ce3
    ------------------------------------------------------------------------------------- :: if
    CS ; G |- if se1 then se2 else se3 <== tau [ eff ] ~~> if ce1 then ce2 else ce3

    CS ; G |- se <== tau [ eff ] ~~> ce
    ---------------------------------- :: return
    CS ; G |- return se <== pred tau [ eff ] ~~> return ce

    CS ; G |- se1 ==> pred tau [ eff' ] ~~> ce1
    eff' <= eff
    CS ; G |- y , noscrs ; pat : tau --> [ empty ] [ hole ] se2 <== pred tau' [ eff ] ~~> ce2
    ------------------------------------------------------------------------------------------------------------------- :: take
    CS ; G |- take pat = se1 ; se2 <== pred tau' [ eff ] ~~> take y = ce1 ; ce2

    CS ; G |- se ==> tau [ eff' ] ~~> ce
    eff' <= eff
    --------------------------------------- :: sub
    CS ; G |- se <== tau [ eff ] ~~> ce


% =============================================================================
% Program elaboration
% =============================================================================

  defn SS ; CS |- prog ~~> cprog :: :: prog :: 'Prog_'
  {{ tex \begin{array}{ @{} l @{} } [[SS]] \vdash [[prog]] \\ \quad \leadsto [[CS]] \vdash [[cprog]] \end{array} }} by

    CS ; G |- se <== tau [ eff ] ~~> ce
    ------------------------------------------------------ :: main
    SS ; CS |- main : tau [ eff ] = se ~~> main : tau [ eff ] = ce

    mbranches = mk A { pat1 --> se1 || .. || patn --> sen }
    CS ; G |- y , noscrs ; mbranches <== B [ pure ] ~~> ce
    SS , fun f : A -> B [ pure ] = { pat1 --> se1 | .. | patn --> sen } ; CS , fun f ( y : A ) -> B [ pure ] = ce |- prog ~~> cprog
    --------------------------------------------------------------------------- :: purefun
    SS ; CS |- fun f : A -> B [ pure ] = { pat1 --> se1 | .. | patn --> sen } prog ~~> fun f ( y : A ) -> B [ pure ] = ce cprog

    mbranches = mk A { pat1 --> se1 || .. || patn --> sen }
    CS , f : A -> B [ impure ] ; G |- y , noscrs ; mbranches <== B [ impure ] ~~> ce
    SS , f : A -> B [ impure ] ; CS , f : A -> B [ impure ] |- prog ~~> cprog
    ------------------------------------------------------------------------------------------------- :: impurefun
    SS ; CS |- fun f : A -> B [ impure ] = { pat1 --> se1 | .. | patn --> sen } prog ~~> fun f ( y : A ) -> B [ impure ] = ce cprog

    mbranches = mk tau { pat1 --> se1 || .. || patn --> sen }
    CS , f : tau -> tau' [ spec ] ; G |- y , noscrs ; mbranches <== tau' [ spec ] ~~> ce
    SS , fun f : tau -> tau' [ spec ] = { pat1 --> se1 | .. | patn --> sen } ; CS , fun f ( y : tau ) -> tau' [ spec ] = ce |- prog ~~> cprog
    ----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------- :: specfun
    SS ; CS |- fun f : tau -> tau' [ spec ] = { pat1 --> se1 | .. | patn --> sen } prog ~~> fun f ( y : tau ) -> tau' [ spec ] = ce cprog

    CS |- sort D ( a1 , .. , ai ) = { L1 : tau1 | .. | Ln : taun } sort_ok
    SS , sort D ( a1 , .. , ai ) = { L1 : tau1 | .. | Ln : taun } ; CS , sort D ( a1 , .. , ai ) = { L1 : tau1 | .. | Ln : taun } |- prog ~~> cprog
    ---------------------------------------------------------------------------- :: sortdecl
    SS ; CS |- sort D ( a1 , .. , ai ) = { L1 : tau1 | .. | Ln : taun } prog ~~> sort D ( a1 , .. , ai ) = { L1 : tau1 | .. | Ln : taun } cprog

    CS |- type D ( a1 , .. , ai ) = { L1 : A1 | .. | Ln : An } type_ok
    SS , type D ( a1 , .. , ai ) = { L1 : A1 | .. | Ln : An } ; CS , type D ( a1 , .. , ai ) = { L1 : A1 | .. | Ln : An } |- prog ~~> cprog
    ---------------------------------------------------------------------------- :: typedecl
    SS ; CS |- type D ( a1 , .. , ai ) = { L1 : A1 | .. | Ln : An } prog ~~> type D ( a1 , .. , ai ) = { L1 : A1 | .. | Ln : An } cprog


% =============================================================================
% Pattern matching (unified)
% =============================================================================

defns Jmatch :: '' ::=

  defn mbranches has_con :: :: has_con :: 'HC_'
  {{ tex [[mbranches]] \;\mathsf{has\_con} }} by

    ---------------------------------------- :: here
    L pat : tau , binds --> [ G ] [ E ] se || mbranches has_con

    mbranches has_con
    ---------------------------------------- :: there
    binds --> [ G ] [ E ] se || mbranches has_con

  defn mbranches has_tup :: :: has_tup :: 'HT_'
  {{ tex [[mbranches]] \;\mathsf{has\_tup} }} by

    ---------------------------------------- :: here
    ( pat1 , .. , patn ) : tau , binds --> [ G ] [ E ] se || mbranches has_tup

    mbranches has_tup
    ---------------------------------------- :: there
    binds --> [ G ] [ E ] se || mbranches has_tup

  defn mbranches / var y [ eff ] ~~> mbranches' :: :: strip_var :: 'SV_'
  {{ tex [[mbranches]] \ottsym{/} \ottmv{var} \overset{[[y]]}{\leadsto}_{[[eff]]} [[mbranches']] }} by

    ---------------------------------------- :: empty
    nobranches / var y [ eff ] ~~> nobranches

    mbranches / var y [ eff ] ~~> mbranches'
    ------------------------------------------------------------------ :: cons
    x : tau , binds --> [ G ] [ E ] se || mbranches / var y [ eff ] ~~> binds --> [ G , x : tau [ eff ] ] [ let x = y ; E ] se || mbranches'

  defn mbranches / L : tau @ y [ eff ] ~~> mbranches' :: :: spec_con :: 'SC_'
  {{ tex [[mbranches]] \ottsym{/} [[L]] \mathord{:} [[tau]] \overset{[[y]]}{\leadsto}_{[[eff]]} [[mbranches']] }} by

    ------------------------------------------------------------------ :: empty
    nobranches / L : tau @ y [ eff ] ~~> nobranches

    mbranches / L : tau @ y [ eff ] ~~> mbranches'
    ------------------------------------------------------------------------------------------------ :: match
    L pat : tau' , binds --> [ G ] [ E ] se || mbranches / L : tau @ y [ eff ] ~~> pat : tau , binds --> [ G ] [ E ] se || mbranches'

    L != L'    mbranches / L : tau @ y [ eff ] ~~> mbranches'
    ------------------------------------------------------------------------------------------------ :: skip
    L' pat : tau' , binds --> [ G ] [ E ] se || mbranches / L : tau @ y [ eff ] ~~> mbranches'

    mbranches / L : tau @ y [ eff ] ~~> mbranches'
    ------------------------------------------------------------------------------------------------------------ :: var
    x : tau' , binds --> [ G ] [ E ] se || mbranches / L : tau @ y [ eff ] ~~> z : tau , binds --> [ G , x : tau' [ eff ] ] [ let x = y ; E ] se || mbranches'

  defn mbranches / tup @ y [ eff ] ~~> mbranches' :: :: expand_tup :: 'ET_'
  {{ tex [[mbranches]] \ottsym{/} \ottkw{tup} \overset{[[y]]}{\leadsto}_{[[eff]]} [[mbranches']] }} by

    -------------------------------------------------------- :: empty
    nobranches / tup @ y [ eff ] ~~> nobranches

    mbranches / tup @ y [ eff ] ~~> mbranches'
    ------------------------------------------------------------------------------------------------------------ :: tuple
    ( pat1 , .. , patk ) : ( tau1 , .. , tauk ) , binds --> [ G ] [ E ] se || mbranches / tup @ y [ eff ] ~~> pat1 : tau1 , .. , patk : tauk , binds --> [ G ] [ E ] se || mbranches'

    mbranches / tup @ y [ eff ] ~~> mbranches'
    ------------------------------------------------------------------------------------------------------------ :: var
    x : ( tau1 , .. , tauk ) , binds --> [ G ] [ E ] se || mbranches / tup @ y [ eff ] ~~> z1 : tau1 , .. , zk : tauk , binds --> [ G , x : ( tau1 , .. , tauk ) [ eff ] ] [ let x = y ; E ] se || mbranches'

  defn CS ; G |- scrs ; mbranches <== tau [ eff ] ~~> ce :: :: coverage :: 'Cov_'
  {{ tex [[CS]] ; [[G]] \vdash [[scrs]] ; [[mbranches]] \Leftarrow_{[[eff]]} [[tau]] \leadsto [[ce]] }} by

    CS ; G , G' |- se <== tau [ eff ] ~~> ce'    ce = fill E ce'
    ------------------------------------------------------------------ :: done
    CS ; G |- noscrs ; nobinds --> [ G' ] [ E ] se || mbranches <== tau [ eff ] ~~> ce

    eff_b = purify eff    mbranches / var y [ eff_b ] ~~> mbranches'
    CS ; G |- scrs ; mbranches' <== tau [ eff ] ~~> ce
    ------------------------------------------------ :: var
    CS ; G |- y , scrs ; mbranches <== tau [ eff ] ~~> ce

    eff_b = purify eff    mbranches has_con
    D ( a1 , .. , ak ) = { L1 : tau'1 | .. | Ln : tau'n } decl_in CS
    L1 : tau''1 in D ( tau1 , .. , taui ) in CS .. Ln : tau''n in D ( tau1 , .. , taui ) in CS
    mbranches / L1 : tau''1 @ y [ eff_b ] ~~> mbranches1 .. mbranches / Ln : tau''n @ y [ eff_b ] ~~> mbranchesn
    CS ; G |- x1 , scrs ; mbranches1 <== tau [ eff ] ~~> ce1 .. CS ; G |- xn , scrs ; mbranchesn <== tau [ eff ] ~~> cen
    --------------------------------------------------------------------------------------------------------- :: con
    CS ; G |- y , scrs ; mbranches <== tau [ eff ] ~~> case y of { L1 x1 -> ce1 | .. | Ln xn -> cen }

    eff_b = purify eff    mbranches has_tup
    mbranches / tup @ y [ eff_b ] ~~> mbranches'
    CS ; G |- y1 , .. , yn , scrs ; mbranches' <== tau [ eff ] ~~> ce
    ----------------------------------------------------------------------------------------------------------------- :: tup
    CS ; G |- y , scrs ; mbranches <== tau [ eff ] ~~> let ( y1 , .. , yn ) = y ; ce

  defn fill E ce ~~> ce' :: :: fill_ctx :: 'Fill_'
  {{ tex [[E]] [ [[ce]] ] \leadsto [[ce']] }} by

    ----------------------- :: hole
    fill hole ce ~~> ce

    fill E ce ~~> ce'
    ------------------------------------------------ :: let
    fill let x = ce'' ; E ce ~~> let x = ce'' ; ce'
