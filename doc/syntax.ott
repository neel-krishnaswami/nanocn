% Core typing (merged computation + assertion)
% =============================================================================

  defn CS ; G |- [ eff0 ] ce ==> tau :: :: synth :: 'Syn_'
  {{ tex [[CS]] ; [[G]] \vdash_{[[eff0]]} [[ce]] \Rightarrow [[tau]] }} by

    ----------------------- :: int
    CS ; G |- [ eff0 ] lit ==> int

    -------------------------- :: bool
    CS ; G |- [ eff0 ] blit ==> bool

    x : tau [ eff' ] in G    eff' <= eff0
    ----------------------- :: var
    CS ; G |- [ eff0 ] x ==> tau

    CS ; G |- [ eff0 ] ce <== tau
    ---------------------------------- :: annot
    CS ; G |- [ eff0 ] ce : tau ==> tau

    prim : tau -> tau' [ eff' ]
    eff' <= eff0
    eff'' = purify eff0
    CS ; G |- [ eff'' ] ce <== tau
    --------------------------------------------------- :: app
    CS ; G |- [ eff0 ] prim ce ==> tau'

    f : tau -> tau' [ eff' ] in CS
    eff' <= eff0
    eff'' = purify eff0
    CS ; G |- [ eff'' ] ce <== tau
    ---------------------------------------- :: call
    CS ; G |- [ eff0 ] f ce ==> tau'

    A eqtype
    eff' = purify eff0
    CS ; G |- [ eff' ] ce1 ==> A
    CS ; G |- [ eff' ] ce2 <== A
    ------------------------------------------------- :: eq
    CS ; G |- [ eff0 ] ce1 == ce2 ==> bool

  defn CS ; G |- [ eff0 ] ce <== tau :: :: check :: 'Chk_'
  {{ tex [[CS]] ; [[G]] \vdash_{[[eff0]]} [[ce]] \Leftarrow [[tau]] }} by

    CS ; G |- [ eff0 ] ce1 ==> tau
    eff_b = purify eff0
    CS ; G , x : tau [ eff_b ] |- [ eff0 ] ce2 <== tau'
    -------------------------------------------------------------------------- :: let
    CS ; G |- [ eff0 ] let x = ce1 ; ce2 <== tau'

    CS ; G |- [ eff0 ] ce1 <== tau1 .. CS ; G |- [ eff0 ] cen <== taun
    --------------------------------------------------- :: tuple
    CS ; G |- [ eff0 ] ( ce1 , .. , cen ) <== ( tau1 , .. , taun )

    eff_b = purify eff0
    CS ; G |- [ eff_b ] ce1 ==> ( tau1 , .. , taun )
    G' = x1 : tau1 [ eff_b ] , .. , xn : taun [ eff_b ]
    CS ; G , G' |- [ eff0 ] ce2 <== tau'
    ---------------------------------------------------------------------------------- :: lettuple
    CS ; G |- [ eff0 ] let ( x1 , .. , xn ) = ce1 ; ce2 <== tau'

    L : tau in D ( tau1 , .. , taui ) in CS
    eff' = purify eff0
    CS ; G |- [ eff' ] ce <== tau
    ----------------------------------------------------------------- :: inject
    CS ; G |- [ eff0 ] L ce <== D ( tau1 , .. , taui )

    eff' = purify eff0
    CS ; G |- [ eff' ] ce ==> D ( tau1 , .. , taui )
    D ( a1 , .. , ak ) = { L1 : tau'1 | .. | Ln : tau'n } decl_in CS
    L1 : tau''1 in D ( tau1 , .. , taui ) in CS .. Ln : tau''n in D ( tau1 , .. , taui ) in CS
    CS ; G , x1 : tau''1 [ eff' ] |- [ eff0 ] ce1 <== tau .. CS ; G , xn : tau''n [ eff' ] |- [ eff0 ] cen <== tau
    ---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------- :: case
    CS ; G |- [ eff0 ] case ce of { L1 x1 -> ce1 | .. | Ln xn -> cen } <== tau

    type D ( x , y ) = { Next : a , Done : b } in CS
    CS ; G |- [ pure ] ce1 ==> A
    CS ; G , x : A [ pure ] |- [ impure ] ce2 <== D ( A , B )
    --------------------------------------------------------------------------------------------------------------------------------------- :: iter
    CS ; G |- [ impure ] iter ( x = ce1 ) { ce2 } <== B

    eff' = purify eff0
    CS ; G |- [ eff' ] ce1 <== bool
    CS ; G |- [ eff0 ] ce2 <== tau
    CS ; G |- [ eff0 ] ce3 <== tau
    ------------------------------------------------------------------------------------- :: if
    CS ; G |- [ eff0 ] if ce1 then ce2 else ce3 <== tau

    CS ; G |- [ spec ] ce <== tau
    ---------------------------------- :: return
    CS ; G |- [ spec ] return ce <== pred tau

    ---------------------------------- :: fail
    CS ; G |- [ spec ] fail <== pred tau

    CS ; G |- [ spec ] ce1 ==> pred tau
    CS ; G , x : tau [ spec ] |- [ spec ] ce2 <== pred tau'
    -------------------------------------------------------------------------- :: take
    CS ; G |- [ spec ] take x = ce1 ; ce2 <== pred tau'

    CS ; G |- [ eff0 ] ce ==> tau
    --------------------------------------- :: sub
    CS ; G |- [ eff0 ] ce <== tau


